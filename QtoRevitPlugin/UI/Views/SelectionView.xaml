<UserControl x:Class="QtoRevitPlugin.UI.Views.SelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QtoRevitPlugin.UI.ViewModels">

    <Grid Background="{DynamicResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Titolo + bottone pop-out -->
        <Grid Grid.Row="0" Margin="16,14,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Selezione Elementi" Style="{DynamicResource ViewTitleStyle}" />
            <TextBlock Grid.Column="1" Text="§ I3 · v1"
                       VerticalAlignment="Bottom"
                       Foreground="{DynamicResource InkMutedBrush}"
                       FontFamily="{DynamicResource FontMono}" FontSize="10"
                       Margin="8,0,0,12" />
            <Button Grid.Column="3" x:Name="BtnPopout" Click="OnPopoutClick"
                    Content="⤢ Apri in finestra"
                    Padding="8,3" FontSize="10"
                    Background="Transparent" Foreground="{DynamicResource InkDimBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    ToolTip="Apre questa scheda in una finestra separata" />
        </Grid>

        <!-- Filtro: fase + categoria + modalità -->
        <Border Grid.Row="1" Style="{DynamicResource CardStyle}" Margin="16,8,16,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="FILTRO" Style="{DynamicResource SectionLabelStyle}" />

                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Text="Fase Revit attiva"
                           Style="{DynamicResource SectionLabelStyle}" />

                <Grid Grid.Row="2" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding AvailablePhases}"
                              SelectedItem="{Binding SelectedPhase, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              FontSize="11"
                              Padding="6,3" />

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Modalità computo"
                                   Style="{DynamicResource SectionLabelStyle}" />
                        <ComboBox Margin="0,6,0,0"
                                  ItemsSource="{Binding ComputationModes}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Mode"
                                  SelectedValue="{Binding ComputationMode, Mode=TwoWay}"
                                  FontSize="11"
                                  Padding="6,3" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Categoria:" Margin="0,0,8,0"
                               VerticalAlignment="Center" FontSize="11" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                              DisplayMemberPath="Label"
                              FontSize="11" Padding="6,3" />
                    <TextBlock Grid.Column="2" Text="Cerca nome:" Margin="12,0,8,0"
                               VerticalAlignment="Center" FontSize="11" />
                    <TextBox Grid.Column="3"
                             Text="{Binding NameQuery, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="11" Padding="6,3"
                             Background="White"
                             BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
                </Grid>

                <TextBlock Grid.Row="4"
                           Margin="0,8,0,0"
                           Text="{Binding ActivePhaseName, StringFormat='La fase corrente aggiorna Selezione, Tagging, Preview e Struttura Computo · «{0}»'}"
                           FontSize="11"
                           FontStyle="Italic"
                           Foreground="{DynamicResource InkMutedBrush}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <!-- Toolbar azioni -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="16,0,16,4">
            <Button x:Name="BtnIsolate" Click="OnIsolateClick"
                    Content="Isola in vista"
                    Padding="10,4" FontSize="11" FontWeight="SemiBold"
                    Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand" />
            <Button x:Name="BtnHide" Click="OnHideClick"
                    Content="Nascondi"
                    Margin="6,0,0,0" Padding="10,4" FontSize="11"
                    Background="Transparent" Foreground="{DynamicResource InkDefaultBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                    Cursor="Hand" />
            <Button x:Name="BtnReset" Click="OnResetClick"
                    Content="Reset vista"
                    Margin="6,0,0,0" Padding="10,4" FontSize="11"
                    Background="Transparent" Foreground="{DynamicResource InkDefaultBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                    Cursor="Hand" />
            <Button x:Name="BtnRefresh" Click="OnRefreshClick"
                    Content="Aggiorna"
                    Margin="6,0,0,0" Padding="10,4" FontSize="11"
                    Background="Transparent" Foreground="{DynamicResource InkDimBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                    Cursor="Hand" />
        </StackPanel>

        <!-- DataGrid risultati -->
        <Border Grid.Row="3" Margin="16,0,16,8"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1">
            <DataGrid x:Name="GridElements"
                      ItemsSource="{Binding Elements}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="22"
                      FontSize="11"
                      Background="White"
                      BorderThickness="0"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      MouseDoubleClick="OnRowDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id"            Binding="{Binding ElementId}"           Width="70"  FontFamily="Consolas" />
                    <DataGridTextColumn Header="Famiglia"      Binding="{Binding FamilyName}"          Width="*" />
                    <DataGridTextColumn Header="Tipo"          Binding="{Binding TypeName}"            Width="*" />
                    <DataGridTextColumn Header="Livello"       Binding="{Binding LevelName}"           Width="80" />
                    <DataGridTextColumn Header="Fase creaz."   Binding="{Binding PhaseCreatedName}"    Width="100" FontSize="10" />
                    <DataGridTextColumn Header="Fase demol."   Binding="{Binding PhaseDemolishedName}" Width="100" FontSize="10" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="4" Background="{DynamicResource PanelSubBrush}"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11" FontStyle="Italic"
                       Foreground="{DynamicResource InkMutedBrush}" />
        </Border>
    </Grid>
</UserControl>
