<UserControl x:Class="QtoRevitPlugin.UI.Views.SelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QtoRevitPlugin.UI.ViewModels">

    <Grid Background="{DynamicResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Titolo + bottone pop-out -->
        <Grid Grid.Row="0" Margin="16,14,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Selezione Elementi" Style="{DynamicResource ViewTitleStyle}" />
            <TextBlock Grid.Column="1" Text="§ I3 · v1"
                       VerticalAlignment="Bottom"
                       Foreground="{DynamicResource InkMutedBrush}"
                       FontFamily="{DynamicResource FontMono}" FontSize="10"
                       Margin="8,0,0,12" />
            <Button Grid.Column="3" x:Name="BtnPopout" Click="OnPopoutClick"
                    Content="⤢ Apri in finestra"
                    Padding="8,3" FontSize="10"
                    Background="Transparent" Foreground="{DynamicResource InkDimBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    ToolTip="Apre questa scheda in una finestra separata" />
        </Grid>

        <!-- Filtro: 3 sezioni numerate -->
        <Border Grid.Row="1" Style="{DynamicResource CardStyle}" Margin="16,8,16,4">
            <StackPanel>

                <!-- Sezione 1 — FASE -->
                <TextBlock Text="1 — FASE" Style="{DynamicResource SectionLabelStyle}" />

                <!-- Filtro fase attiva -->
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <CheckBox IsChecked="{Binding FilterByActivePhase, Mode=TwoWay}"
                              Content="Filtra per fase attiva della sessione"
                              FontSize="11"
                              VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ActivePhaseName, StringFormat=' · «{0}»'}"
                               Margin="4,0,0,0"
                               FontSize="11" FontStyle="Italic"
                               Foreground="{DynamicResource InkMutedBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Separatore -->
                <Border Height="1" Background="{DynamicResource EdgeLightBrush}" Margin="0,10,0,8"/>

                <!-- Sezione 2 — CATEGORIA -->
                <TextBlock Text="2 — CATEGORIA" Style="{DynamicResource SectionLabelStyle}" />

                <!-- Categoria + ricerca -->
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Categoria:" Margin="0,0,8,0"
                               VerticalAlignment="Center" FontSize="11" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                              DisplayMemberPath="Label"
                              FontSize="11" Padding="6,3" />
                    <TextBlock Grid.Column="2" Text="Cerca nome:" Margin="12,0,8,0"
                               VerticalAlignment="Center" FontSize="11" />
                    <TextBox Grid.Column="3"
                             Text="{Binding NameQuery, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="11" Padding="6,3"
                             Background="White"
                             BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
                </Grid>

                <!-- Separatore -->
                <Border Height="1" Background="{DynamicResource EdgeLightBrush}" Margin="0,10,0,8"/>

                <!-- Sezione 3 — FILTRI PARAMETRICI -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="3 — FILTRI PARAMETRICI"
                               Style="{DynamicResource SectionLabelStyle}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Command="{Binding AddParamRuleCommand}"
                            Content="+ Aggiungi filtro"
                            Padding="8,3" FontSize="10" Cursor="Hand"
                            Background="Transparent" Foreground="{DynamicResource InkDefaultBrush}"
                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"/>
                </Grid>

                <ItemsControl x:Name="ParamRulesList" ItemsSource="{Binding ParamRules}" Margin="0,6,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="120"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*" MinWidth="80"/>
                                    <ColumnDefinition Width="22"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding ParameterName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="11" Padding="5,3"
                                         BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                         ToolTip="Nome esatto del parametro Revit (es: Spessore, Area, Materiale struttura)"/>
                                <ComboBox Grid.Column="1" Margin="4,0"
                                          ItemsSource="{x:Static vm:ParamFilterRuleVm.OperatorLabels}"
                                          SelectedItem="{Binding OperatorLabel, Mode=TwoWay}"
                                          FontSize="11" Padding="5,2"/>
                                <TextBox Grid.Column="2"
                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="11" Padding="5,3"
                                         BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                         ToolTip="Valore in unità di progetto (es: 0.30 per 30 cm, 10.5 per 10.5 m²)"/>
                                <Button Grid.Column="3" Margin="4,0,0,0"
                                        Command="{Binding DataContext.RemoveParamRuleCommand,
                                                  Source={x:Reference ParamRulesList}}"
                                        CommandParameter="{Binding}"
                                        Content="×" FontSize="13" FontWeight="Bold"
                                        Background="Transparent" Foreground="{DynamicResource InkMutedBrush}"
                                        BorderThickness="0" Cursor="Hand" ToolTip="Rimuovi filtro"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="0,5,0,0" FontSize="10" FontStyle="Italic"
                           Foreground="{DynamicResource InkMutedBrush}" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasParamRules}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    &#x26A0; Valori numerici in unità di progetto (lunghezze in m, aree in m²). Testi case-insensitive.
                </TextBlock>

            </StackPanel>
        </Border>

        <!-- Toolbar azioni -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="16,0,16,4">
            <Button x:Name="BtnIsolate" Click="OnIsolateClick"
                    Content="Isola in vista"
                    Padding="10,4" FontSize="11" FontWeight="SemiBold"
                    Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand" />
            <Button x:Name="BtnHide" Click="OnHideClick"
                    Content="Nascondi"
                    Margin="6,0,0,0" Padding="10,4" FontSize="11"
                    Background="Transparent" Foreground="{DynamicResource InkDefaultBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                    Cursor="Hand" />
            <Button x:Name="BtnReset" Click="OnResetClick"
                    Content="Reset vista"
                    Margin="6,0,0,0" Padding="10,4" FontSize="11"
                    Background="Transparent" Foreground="{DynamicResource InkDefaultBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                    Cursor="Hand" />
            <Button x:Name="BtnRefresh" Click="OnRefreshClick"
                    Content="Aggiorna"
                    Margin="6,0,0,0" Padding="10,4" FontSize="11"
                    Background="Transparent" Foreground="{DynamicResource InkDimBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                    Cursor="Hand" />
        </StackPanel>

        <!-- DataGrid risultati -->
        <Border Grid.Row="3" Margin="16,0,16,8"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1">
            <DataGrid x:Name="GridElements"
                      ItemsSource="{Binding Elements}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="22"
                      FontSize="11"
                      Background="White"
                      BorderThickness="0"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      MouseDoubleClick="OnRowDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id"            Binding="{Binding ElementId}"           Width="70"  FontFamily="Consolas" />
                    <DataGridTextColumn Header="Famiglia"      Binding="{Binding FamilyName}"          Width="*" />
                    <DataGridTextColumn Header="Tipo"          Binding="{Binding TypeName}"            Width="*" />
                    <DataGridTextColumn Header="Livello"       Binding="{Binding LevelName}"           Width="80" />
                    <DataGridTextColumn Header="Fase creaz."   Binding="{Binding PhaseCreatedName}"    Width="100" FontSize="10" />
                    <DataGridTextColumn Header="Fase demol."   Binding="{Binding PhaseDemolishedName}" Width="100" FontSize="10" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="4" Background="{DynamicResource PanelSubBrush}"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11" FontStyle="Italic"
                       Foreground="{DynamicResource InkMutedBrush}" />
        </Border>
    </Grid>
</UserControl>
