<Window x:Class="QtoRevitPlugin.UI.Views.ReconciliationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifiche Modello Rilevate"
        Width="700" Height="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"
                   Text="Confronto con lo stato precedente del modello"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Eliminati -->
                <TextBlock FontWeight="Bold" Foreground="Red" Margin="0,0,0,4">
                    <Run Text="ELIMINATI ("/>
                    <Run Text="{Binding DeletedCount}"/>
                    <Run Text=")"/>
                </TextBlock>
                <ItemsControl ItemsSource="{Binding DeletedItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#FFE0E0" BorderThickness="1" Margin="0,2" Padding="6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ElementLabel}" Width="130"/>
                                    <TextBlock Text="{Binding EpCode}" Width="100" Foreground="Gray"/>
                                    <TextBlock Text="{Binding OldQtyLabel}" Width="70"/>
                                    <CheckBox Content="Accetta" IsChecked="{Binding Accepted, Mode=TwoWay}" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Modificati -->
                <TextBlock FontWeight="Bold" Foreground="DarkOrange" Margin="0,8,0,4">
                    <Run Text="MODIFICATI ("/>
                    <Run Text="{Binding ModifiedCount}"/>
                    <Run Text=")"/>
                </TextBlock>
                <ItemsControl ItemsSource="{Binding ModifiedItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#FFF0D0" BorderThickness="1" Margin="0,2" Padding="6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ElementLabel}" Width="130"/>
                                    <TextBlock Text="{Binding OldQtyLabel}" Width="60"/>
                                    <TextBlock Text=" -> " Width="20"/>
                                    <TextBlock Text="{Binding NewQtyLabel}" Width="60"/>
                                    <TextBlock Text="{Binding Delta}" Width="60" Foreground="DarkOrange"/>
                                    <CheckBox Content="Accetta" IsChecked="{Binding Accepted, Mode=TwoWay}" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Nuovi -->
                <TextBlock FontWeight="Bold" Foreground="SteelBlue" Margin="0,8,0,4">
                    <Run Text="NUOVI ("/>
                    <Run Text="{Binding AddedCount}"/>
                    <Run Text=") - non ancora computati"/>
                </TextBlock>
                <ItemsControl ItemsSource="{Binding AddedItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#D0E8FF" BorderThickness="1" Margin="0,2" Padding="6">
                                <TextBlock Text="{Binding UniqueId}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Accetta TUTTO" Command="{Binding AcceptAllCommand}"
                    Padding="12,4" Margin="0,0,8,0"/>
            <Button Content="Ignora TUTTO" Command="{Binding IgnoreAllCommand}"
                    Padding="12,4" Margin="0,0,8,0"/>
            <Button Padding="12,4" Margin="0,0,8,0"
                    Background="#1E6FD9" Foreground="White"
                    Command="{Binding ApplyBatchCommand}">
                <Button.Content>
                    <TextBlock>
                        <Run Text="Applica selezionate ("/>
                        <Run Text="{Binding AcceptedCount, Mode=OneWay}"/>
                        <Run Text=")"/>
                    </TextBlock>
                </Button.Content>
            </Button>
            <Button Content="Chiudi" Click="OnCloseClick" Padding="12,4"/>
        </StackPanel>
    </Grid>
</Window>
