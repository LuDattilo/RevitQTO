<Window x:Class="QtoRevitPlugin.UI.Views.PickEpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CME — Scegli voce EP"
        Width="760" Height="560"
        MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBgBrush}"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/QtoRevitPlugin;component/Theme/QtoTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- 0 header -->
            <RowDefinition Height="Auto" />
            <!-- 1 filters (listino + search) -->
            <RowDefinition Height="Auto" />
            <!-- 2 AI suggestions (collassato se vuoto) -->
            <RowDefinition Height="*" />
            <!-- 3 lista voci -->
            <RowDefinition Height="Auto" />
            <!-- 4 quantity radios -->
            <RowDefinition Height="Auto" />
            <!-- 5 preview totale -->
            <RowDefinition Height="Auto" />
            <!-- 6 footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Scegli voce EP"
                       FontFamily="{DynamicResource FontDisplay}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ChromeTextBrush}" />
            <TextBlock x:Name="SubtitleBlock"
                       Margin="0,4,0,0"
                       FontSize="11"
                       Foreground="{DynamicResource ChromeTextDimBrush}"
                       Text="Seleziona una voce dal listino attivo per tagghere gli elementi selezionati." />
        </StackPanel>

        <!-- Filtri: listino sorgente + ricerca -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Listino:" Margin="0,0,8,0"
                       VerticalAlignment="Center" FontSize="11"
                       Foreground="{DynamicResource ChromeTextBrush}" />
            <ComboBox Grid.Column="1"
                      x:Name="ListCombo"
                      SelectionChanged="OnListChanged"
                      FontSize="11" Padding="6,3" />

            <TextBlock Grid.Column="2" Text="Cerca:" Margin="16,0,8,0"
                       VerticalAlignment="Center" FontSize="11"
                       Foreground="{DynamicResource ChromeTextBrush}" />
            <TextBox Grid.Column="3"
                     x:Name="SearchBox"
                     TextChanged="OnSearchChanged"
                     FontSize="11" Padding="6,3" />
        </Grid>

        <!-- Suggerimenti AI (collassato se vuoto) -->
        <Border x:Name="AiSuggestionsBorder"
                Grid.Row="2"
                Margin="0,0,0,8"
                Padding="8,6"
                Background="{DynamicResource BrandAccentSoftBrush}"
                BorderBrush="{DynamicResource BrandAccentBrush}" BorderThickness="1"
                CornerRadius="4"
                Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="●"
                               Foreground="{DynamicResource BrandAccentBrush}"
                               FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="SUGGERIMENTI AI"
                               FontFamily="{DynamicResource FontMono}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource ChromeTextDimBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="AiSuggestionsHint"
                               Margin="8,0,0,0"
                               FontSize="10" FontStyle="Italic"
                               Foreground="{DynamicResource ChromeTextDimBrush}"
                               VerticalAlignment="Center"
                               Text="" />
                </StackPanel>
                <ItemsControl x:Name="AiSuggestionsList" Margin="0,4,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Chip cliccabile: auto-seleziona la voce nella lista sottostante -->
                            <Button Margin="0,0,6,4"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="OnAiSuggestionClick"
                                    Tag="{Binding Code}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ChipBg"
                                                Background="{DynamicResource PanelSubBrush}"
                                                BorderBrush="{DynamicResource BrandAccentBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="10,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Code}"
                                                           FontFamily="{DynamicResource FontMono}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ChromeTextBrush}" />
                                                <TextBlock Text=" · "
                                                           Foreground="{DynamicResource ChromeTextDimBrush}"
                                                           FontSize="10" />
                                                <TextBlock Text="{Binding ShortLabel}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource ChromeTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="260" />
                                                <TextBlock Text=" · "
                                                           Foreground="{DynamicResource ChromeTextDimBrush}"
                                                           FontSize="10" />
                                                <TextBlock Text="{Binding ScoreLabel}"
                                                           FontFamily="{DynamicResource FontMono}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrandAccentBrush}" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ChipBg" Property="Background" Value="{DynamicResource BrandAccentSoftBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Lista voci -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource EdgeLightBrush}"
                BorderThickness="1">
            <ListView x:Name="ItemsList"
                      Background="{DynamicResource PanelSubBrush}"
                      BorderThickness="0"
                      FontSize="11"
                      SelectionMode="Single"
                      MouseDoubleClick="OnItemDoubleClick"
                      SelectionChanged="OnItemsListSelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="Padding" Value="6,4" />
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Header="Codice" Width="140" DisplayMemberBinding="{Binding Code}" />
                        <GridViewColumn Header="Descrizione" Width="340" DisplayMemberBinding="{Binding ShortDescription}" />
                        <GridViewColumn Header="U.M." Width="60" DisplayMemberBinding="{Binding Unit}" />
                        <GridViewColumn Header="Prezzo" Width="100" DisplayMemberBinding="{Binding UnitPriceFormatted}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Sezione Quantità (radio + etichetta categoria) -->
        <Border Grid.Row="4" Margin="0,12,0,0"
                Padding="10,8"
                Background="{DynamicResource PanelSubBrush}"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                CornerRadius="4">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="QUANTITÀ PER ISTANZA"
                               FontFamily="{DynamicResource FontMono}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource ChromeTextDimBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="CategoryHintBlock"
                               Margin="8,0,0,0"
                               FontSize="10" FontStyle="Italic"
                               Foreground="{DynamicResource ChromeTextDimBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <RadioButton x:Name="RadioCount" GroupName="QtyMode"
                                 Content="Conteggio (cad.)"
                                 Checked="OnQtyModeChanged"
                                 Margin="0,0,14,0" FontSize="11"
                                 Foreground="{DynamicResource ChromeTextBrush}" />
                    <RadioButton x:Name="RadioArea" GroupName="QtyMode"
                                 Content="Area (m²)"
                                 Checked="OnQtyModeChanged"
                                 Margin="0,0,14,0" FontSize="11"
                                 Foreground="{DynamicResource ChromeTextBrush}" />
                    <RadioButton x:Name="RadioVolume" GroupName="QtyMode"
                                 Content="Volume (m³)"
                                 Checked="OnQtyModeChanged"
                                 Margin="0,0,14,0" FontSize="11"
                                 Foreground="{DynamicResource ChromeTextBrush}" />
                    <RadioButton x:Name="RadioLength" GroupName="QtyMode"
                                 Content="Lunghezza (m)"
                                 Checked="OnQtyModeChanged"
                                 FontSize="11"
                                 Foreground="{DynamicResource ChromeTextBrush}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Anteprima totale preventivo -->
        <Border Grid.Row="5" Margin="0,8,0,0"
                Padding="10,8"
                Background="{DynamicResource BrandAccentSoftBrush}"
                BorderBrush="{DynamicResource BrandAccentBrush}" BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="ANTEPRIMA"
                           FontFamily="{DynamicResource FontMono}"
                           FontSize="9" FontWeight="Bold"
                           Foreground="{DynamicResource ChromeTextDimBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           x:Name="PreviewQuantityBlock"
                           Margin="8,0,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource ChromeTextBrush}"
                           VerticalAlignment="Center"
                           Text="—" />
                <TextBlock Grid.Column="2"
                           x:Name="PreviewAmountBlock"
                           FontFamily="{DynamicResource FontDisplay}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource ChromeTextBrush}"
                           VerticalAlignment="Center"
                           Text="€ 0,00" />
            </Grid>
        </Border>

        <!-- Footer: OK / Annulla -->
        <StackPanel Grid.Row="6" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="FooterStatus"
                       VerticalAlignment="Center" Margin="0,0,16,0"
                       FontSize="10"
                       Foreground="{DynamicResource ChromeTextDimBrush}" />
            <Button Content="Annulla"
                    Click="OnCancelClick"
                    Padding="14,4" FontSize="11"
                    MinWidth="100"
                    Background="Transparent"
                    Foreground="{DynamicResource ChromeTextBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
            <Button x:Name="OkButton"
                    Content="Usa questa voce"
                    Click="OnOkClick"
                    Margin="8,0,0,0" Padding="14,4" FontSize="11" FontWeight="SemiBold"
                    MinWidth="140"
                    IsDefault="True"
                    IsEnabled="False"
                    Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                    BorderThickness="0" />
        </StackPanel>
    </Grid>
</Window>
