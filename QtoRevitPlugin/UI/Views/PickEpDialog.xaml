<Window x:Class="QtoRevitPlugin.UI.Views.PickEpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CME — Scegli voce EP"
        Width="760" Height="560"
        MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBgBrush}"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/QtoRevitPlugin;component/Theme/QtoTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Scegli voce EP"
                       FontFamily="{DynamicResource FontDisplay}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ChromeTextBrush}" />
            <TextBlock x:Name="SubtitleBlock"
                       Margin="0,4,0,0"
                       FontSize="11"
                       Foreground="{DynamicResource ChromeTextDimBrush}"
                       Text="Seleziona una voce dal listino attivo per tagghere gli elementi selezionati." />
        </StackPanel>

        <!-- Filtri: listino sorgente + ricerca -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Listino:" Margin="0,0,8,0"
                       VerticalAlignment="Center" FontSize="11"
                       Foreground="{DynamicResource ChromeTextBrush}" />
            <ComboBox Grid.Column="1"
                      x:Name="ListCombo"
                      SelectionChanged="OnListChanged"
                      FontSize="11" Padding="6,3" />

            <TextBlock Grid.Column="2" Text="Cerca:" Margin="16,0,8,0"
                       VerticalAlignment="Center" FontSize="11"
                       Foreground="{DynamicResource ChromeTextBrush}" />
            <TextBox Grid.Column="3"
                     x:Name="SearchBox"
                     TextChanged="OnSearchChanged"
                     FontSize="11" Padding="6,3" />
        </Grid>

        <!-- Lista voci -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource EdgeLightBrush}"
                BorderThickness="1">
            <ListView x:Name="ItemsList"
                      Background="{DynamicResource PanelSubBrush}"
                      BorderThickness="0"
                      FontSize="11"
                      SelectionMode="Single"
                      MouseDoubleClick="OnItemDoubleClick"
                      SelectionChanged="OnItemsListSelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="Padding" Value="6,4" />
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Header="Codice" Width="140" DisplayMemberBinding="{Binding Code}" />
                        <GridViewColumn Header="Descrizione" Width="340" DisplayMemberBinding="{Binding ShortDescription}" />
                        <GridViewColumn Header="U.M." Width="60" DisplayMemberBinding="{Binding Unit}" />
                        <GridViewColumn Header="Prezzo" Width="100" DisplayMemberBinding="{Binding UnitPriceFormatted}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Sezione Quantità (radio + etichetta categoria) -->
        <Border Grid.Row="3" Margin="0,12,0,0"
                Padding="10,8"
                Background="{DynamicResource PanelSubBrush}"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                CornerRadius="4">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="QUANTITÀ PER ISTANZA"
                               FontFamily="{DynamicResource FontMono}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource ChromeTextDimBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="CategoryHintBlock"
                               Margin="8,0,0,0"
                               FontSize="10" FontStyle="Italic"
                               Foreground="{DynamicResource ChromeTextDimBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <RadioButton x:Name="RadioCount" GroupName="QtyMode"
                                 Content="Conteggio (cad.)"
                                 Checked="OnQtyModeChanged"
                                 Margin="0,0,14,0" FontSize="11"
                                 Foreground="{DynamicResource ChromeTextBrush}" />
                    <RadioButton x:Name="RadioArea" GroupName="QtyMode"
                                 Content="Area (m²)"
                                 Checked="OnQtyModeChanged"
                                 Margin="0,0,14,0" FontSize="11"
                                 Foreground="{DynamicResource ChromeTextBrush}" />
                    <RadioButton x:Name="RadioVolume" GroupName="QtyMode"
                                 Content="Volume (m³)"
                                 Checked="OnQtyModeChanged"
                                 Margin="0,0,14,0" FontSize="11"
                                 Foreground="{DynamicResource ChromeTextBrush}" />
                    <RadioButton x:Name="RadioLength" GroupName="QtyMode"
                                 Content="Lunghezza (m)"
                                 Checked="OnQtyModeChanged"
                                 FontSize="11"
                                 Foreground="{DynamicResource ChromeTextBrush}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Anteprima totale preventivo -->
        <Border Grid.Row="4" Margin="0,8,0,0"
                Padding="10,8"
                Background="{DynamicResource BrandAccentSoftBrush}"
                BorderBrush="{DynamicResource BrandAccentBrush}" BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="ANTEPRIMA"
                           FontFamily="{DynamicResource FontMono}"
                           FontSize="9" FontWeight="Bold"
                           Foreground="{DynamicResource ChromeTextDimBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           x:Name="PreviewQuantityBlock"
                           Margin="8,0,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource ChromeTextBrush}"
                           VerticalAlignment="Center"
                           Text="—" />
                <TextBlock Grid.Column="2"
                           x:Name="PreviewAmountBlock"
                           FontFamily="{DynamicResource FontDisplay}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource ChromeTextBrush}"
                           VerticalAlignment="Center"
                           Text="€ 0,00" />
            </Grid>
        </Border>

        <!-- Footer: OK / Annulla -->
        <StackPanel Grid.Row="5" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="FooterStatus"
                       VerticalAlignment="Center" Margin="0,0,16,0"
                       FontSize="10"
                       Foreground="{DynamicResource ChromeTextDimBrush}" />
            <Button Content="Annulla"
                    Click="OnCancelClick"
                    Padding="14,4" FontSize="11"
                    MinWidth="100"
                    Background="Transparent"
                    Foreground="{DynamicResource ChromeTextBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
            <Button x:Name="OkButton"
                    Content="Usa questa voce"
                    Click="OnOkClick"
                    Margin="8,0,0,0" Padding="14,4" FontSize="11" FontWeight="SemiBold"
                    MinWidth="140"
                    IsDefault="True"
                    IsEnabled="False"
                    Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                    BorderThickness="0" />
        </StackPanel>
    </Grid>
</Window>
