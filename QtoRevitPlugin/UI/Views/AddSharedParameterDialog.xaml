<Window x:Class="QtoRevitPlugin.UI.Views.AddSharedParameterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CME — Crea parametro condiviso"
        Width="560" Height="360"
        MinWidth="460" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBgBrush}"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/QtoRevitPlugin;component/Theme/QtoTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Crea un parametro condiviso"
                       FontFamily="{DynamicResource FontDisplay}"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource ChromeTextBrush}" />
            <TextBlock x:Name="SubtitleBlock"
                       Margin="0,4,0,0"
                       FontSize="11"
                       Foreground="{DynamicResource ChromeTextDimBrush}"
                       TextWrapping="Wrap"
                       Text="Il parametro sarà creato nel file Shared Parameters scelto e legato a ProjectInformation come Instance Parameter. Potrai selezionarlo dal dropdown della scheda Informazioni Progetto." />
        </StackPanel>

        <!-- Nome parametro -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Nome parametro"
                       FontFamily="{DynamicResource FontMono}"
                       FontSize="9" FontWeight="Bold"
                       Foreground="{DynamicResource ChromeTextDimBrush}" />
            <TextBox x:Name="NameBox"
                     Margin="0,4,0,0"
                     FontSize="12" Padding="6,4"
                     TextChanged="OnNameChanged" />
            <TextBlock x:Name="NameHint"
                       Margin="0,4,0,0"
                       FontSize="10"
                       Foreground="{DynamicResource ChromeTextDimBrush}"
                       Text="Suggerito: CME_&lt;FieldKey&gt;. Puoi rinominarlo." />
        </StackPanel>

        <!-- Descrizione (opzionale) -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Descrizione (opzionale)"
                       FontFamily="{DynamicResource FontMono}"
                       FontSize="9" FontWeight="Bold"
                       Foreground="{DynamicResource ChromeTextDimBrush}" />
            <TextBox x:Name="DescBox"
                     Margin="0,4,0,0"
                     FontSize="11" Padding="6,4" />
        </StackPanel>

        <!-- Scelta file SP -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="File Shared Parameters"
                       FontFamily="{DynamicResource FontMono}"
                       FontSize="9" FontWeight="Bold"
                       Foreground="{DynamicResource ChromeTextDimBrush}" />
            <StackPanel Margin="0,4,0,0">
                <RadioButton x:Name="RadioProjectSp"
                             GroupName="SpFile"
                             IsChecked="True"
                             FontSize="11"
                             Foreground="{DynamicResource ChromeTextBrush}"
                             Content="File SP del progetto corrente" />
                <TextBlock x:Name="ProjectSpPathBlock"
                           Margin="22,2,0,0"
                           FontSize="10"
                           FontFamily="{DynamicResource FontMono}"
                           Foreground="{DynamicResource ChromeTextDimBrush}"
                           TextTrimming="CharacterEllipsis"
                           Text="(verrà mostrato al caricamento)" />
                <RadioButton x:Name="RadioCmeSp"
                             GroupName="SpFile"
                             Margin="0,6,0,0"
                             FontSize="11"
                             Foreground="{DynamicResource ChromeTextBrush}"
                             Content="File CME dedicato (%AppData%\QtoPlugin\CME_SharedParameters.txt)" />
            </StackPanel>
        </StackPanel>

        <!-- Footer -->
        <StackPanel Grid.Row="5" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="StatusBlock"
                       VerticalAlignment="Center" Margin="0,0,16,0"
                       FontSize="10"
                       Foreground="{DynamicResource ChromeTextDimBrush}" />
            <Button Content="Annulla"
                    Click="OnCancelClick"
                    Padding="14,4" FontSize="11"
                    MinWidth="100"
                    Background="Transparent"
                    Foreground="{DynamicResource ChromeTextBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
            <Button x:Name="CreateButton"
                    Content="Crea e aggiungi"
                    Click="OnCreateClick"
                    Margin="8,0,0,0" Padding="14,4" FontSize="11" FontWeight="SemiBold"
                    MinWidth="140"
                    IsDefault="True"
                    Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                    BorderThickness="0" />
        </StackPanel>
    </Grid>
</Window>
