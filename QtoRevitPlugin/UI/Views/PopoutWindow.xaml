<Window x:Class="QtoRevitPlugin.UI.Views.PopoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CME"
        Width="1200" Height="820"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="{DynamicResource PanelBgBrush}">
    <!-- Host generico per una UserControl estratta da un tab del DockablePane.
         L'utente apre la scheda in finestra separata per avere più spazio in workflow
         multi-monitor. I bottoni standard Window (minimize/maximize/close) sono forniti
         automaticamente da WPF. -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header scuro con branding + titolo scheda estratta -->
        <Border Grid.Row="0" Background="{DynamicResource ChromeBgBrush}" Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Logo Q arancione -->
                <Border Grid.Column="0"
                        Background="{DynamicResource BrandAccentBrush}"
                        Width="22" Height="22" CornerRadius="2"
                        VerticalAlignment="Center">
                    <TextBlock Text="Q" Foreground="White"
                               FontFamily="{DynamicResource FontDisplay}"
                               FontSize="13" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <!-- Titolo scheda -->
                <TextBlock Grid.Column="1"
                           x:Name="TitleLabel"
                           Text="CME · Scheda"
                           Foreground="{DynamicResource ChromeTextBrush}"
                           FontFamily="{DynamicResource FontDisplay}"
                           FontSize="13" FontWeight="Bold"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center" />

                <!-- Hint -->
                <TextBlock Grid.Column="2"
                           Text="Finestra separata · sincronizzata con il pane principale tramite UserLibrary condivisa"
                           Foreground="{DynamicResource ChromeTextDimBrush}"
                           FontSize="10" FontStyle="Italic"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <!-- Content: qualsiasi UserControl passata via ctor -->
        <ContentPresenter Grid.Row="1" x:Name="ContentHost" />
    </Grid>
</Window>
