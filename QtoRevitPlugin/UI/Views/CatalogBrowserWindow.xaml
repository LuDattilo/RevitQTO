<Window x:Class="QtoRevitPlugin.UI.Views.CatalogBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:QtoRevitPlugin.UI.Views"
        Title="CME · Sfoglia Listino"
        Width="1100" Height="780"
        MinWidth="800" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="{DynamicResource PanelBgBrush}">

    <!--
        Pannello "Sfoglia Listino" — rev.5 (feedback utente 2026-04-23):
        "copia layout listino dal pannello principale adattando per sfoglia listino".

        Il Browser ora NON ridisegna una UI diversa: embed SetupListinoView, la stessa
        UserControl della scheda Listino del pane principale. Così l'UX è identica:
        stessa DataGrid con colonna "Preferiti", stesso SearchBox, stesso dettaglio,
        stesso Expander "I Miei Preferiti" in basso, stessi context menu e drag&drop.

        Il SetupViewModel è condiviso con il pane principale (singleton via SetupView),
        quindi i preferiti aggiunti qui appaiono anche nel pane e viceversa.
    -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/QtoRevitPlugin;component/Theme/QtoTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header scuro di contesto -->
        <Border Grid.Row="0" Background="{DynamicResource ChromeBgBrush}" Padding="16,10">
            <StackPanel>
                <TextBlock Text="SFOGLIA LISTINO"
                           Foreground="{DynamicResource ChromeTextBrush}"
                           FontFamily="{DynamicResource FontMono}" FontSize="11" FontWeight="Bold" />
                <TextBlock Text="Finestra dedicata a ricerca voci, preferiti e dettaglio — sincronizzata col pannello principale"
                           Foreground="{DynamicResource ChromeTextDimBrush}"
                           FontSize="11" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- Contenuto: stessa SetupListinoView del pane principale (VM condiviso) -->
        <views:SetupListinoView x:Name="EmbeddedSetupListino" Grid.Row="1" />

        <!-- Footer chiudi -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Click="OnCloseClick"
                        Content="Chiudi"
                        Padding="14,4" FontSize="11" FontWeight="SemiBold"
                        Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                        BorderThickness="0" Cursor="Hand" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
