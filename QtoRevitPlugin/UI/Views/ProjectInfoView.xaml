<UserControl x:Class="QtoRevitPlugin.UI.Views.ProjectInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QtoRevitPlugin.UI.ViewModels">
    <UserControl.DataContext>
        <vm:ProjectInfoViewModel/>
    </UserControl.DataContext>

    <Grid Background="{DynamicResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Titolo view -->
        <Grid Grid.Row="0" Margin="16,14,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Informazioni Progetto" Style="{DynamicResource ViewTitleStyle}" />
            <TextBlock Grid.Column="1" Text="§ Fase 1 · metadati computo"
                       VerticalAlignment="Bottom"
                       Foreground="{DynamicResource InkMutedBrush}"
                       FontFamily="{DynamicResource FontMono}" FontSize="10"
                       Margin="8,0,0,12" />
        </Grid>

        <!-- Contenuto scrollabile -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Style="{DynamicResource CardStyle}" Margin="16,8,16,16">
                <StackPanel>
                    <TextBlock Text="METADATI COMPUTO · INTESTAZIONE EXPORT XPWE / XLSX"
                               Style="{DynamicResource SectionLabelStyle}" />
                    <TextBlock Margin="0,4,0,8"
                               Text="Ogni campo può essere compilato a mano o ereditato da un parametro del modello Revit via dropdown «Sorgente». Con «+ Aggiungi parametro condiviso…» crei un nuovo Shared Parameter e lo leghi a ProjectInformation."
                               TextWrapping="Wrap"
                               FontSize="10"
                               Foreground="{DynamicResource InkMutedBrush}" />

                    <!-- Selector inline per gli 11 FieldKey (ProjectInfoFieldKeys.All) -->
                    <ItemsControl ItemsSource="{Binding FieldRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="240" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Label}"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource InkDefaultBrush}" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="11" Padding="6,4" />
                                    <ComboBox Grid.Column="3"
                                              ItemsSource="{Binding ParamSources}"
                                              SelectedItem="{Binding SelectedSource, Mode=TwoWay}"
                                              DisplayMemberPath="DisplayName"
                                              FontSize="11" Padding="6,3"
                                              ToolTip="Sorgente del valore: manuale, parametro del modello o crea nuovo Shared Parameter." />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Campi senza selector (date, ribasso, logo) -->
                    <TextBlock Text="DATE E PARAMETRI GARA"
                               Style="{DynamicResource SectionLabelStyle}"
                               Margin="0,18,0,0" />

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Data computo" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <DatePicker SelectedDate="{Binding DataComputo}" FontSize="11" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Data prezzi listino" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <DatePicker SelectedDate="{Binding DataPrezzi}" FontSize="11" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Ribasso d'asta (%)" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <TextBox Text="{Binding RibassoPercentuale, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                        </StackPanel>
                    </Grid>

                    <!-- Footer: Save + status -->
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding StatusMessage}"
                                   VerticalAlignment="Center"
                                   FontSize="10" FontStyle="Italic"
                                   Foreground="{DynamicResource InkMutedBrush}" />
                        <Button Grid.Column="1"
                                Content="📋 Copia da altro CME…"
                                Click="OnCopyFromOtherCmeClick"
                                Padding="10,4" FontSize="11"
                                Background="Transparent"
                                Foreground="{DynamicResource InkDefaultBrush}"
                                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                Margin="0,0,6,0" Cursor="Hand"
                                ToolTip="Apre un altro file .cme e copia le informazioni di progetto nei campi vuoti (non sovrascrive)." />
                        <Button Grid.Column="2"
                                Content="💾 Salva"
                                Command="{Binding SaveCommand}"
                                Padding="12,4" FontSize="11" FontWeight="SemiBold"
                                Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                                BorderThickness="0" Cursor="Hand" />
                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
