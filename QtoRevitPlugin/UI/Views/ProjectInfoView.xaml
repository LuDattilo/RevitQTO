<UserControl x:Class="QtoRevitPlugin.UI.Views.ProjectInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QtoRevitPlugin.UI.ViewModels">
    <UserControl.DataContext>
        <vm:ProjectInfoViewModel/>
    </UserControl.DataContext>

    <Grid Background="{DynamicResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Titolo view -->
        <Grid Grid.Row="0" Margin="16,14,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Informazioni Progetto" Style="{DynamicResource ViewTitleStyle}" />
            <TextBlock Grid.Column="1" Text="§ Fase 1 · metadati computo"
                       VerticalAlignment="Bottom"
                       Foreground="{DynamicResource InkMutedBrush}"
                       FontFamily="{DynamicResource FontMono}" FontSize="10"
                       Margin="8,0,0,12" />
        </Grid>

        <!-- Contenuto scrollabile -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Style="{DynamicResource CardStyle}" Margin="16,8,16,16">
                <StackPanel>
                    <TextBlock Text="METADATI COMPUTO (PERSISTITI NEL .CME · USATI NELL'INTESTAZIONE EXPORT XPWE)"
                               Style="{DynamicResource SectionLabelStyle}" />

                    <!-- Riga 1: Denominazione Opera + Committente -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Denominazione opera" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <TextBox Text="{Binding DenominazioneOpera, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Committente" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <TextBox Text="{Binding Committente, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                        </StackPanel>
                    </Grid>

                    <!-- Riga 2: Impresa + RUP -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Impresa appaltatrice" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <TextBox Text="{Binding Impresa, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Responsabile Unico del Procedimento (RUP)" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <TextBox Text="{Binding Rup, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                        </StackPanel>
                    </Grid>

                    <!-- Riga 3: Direttore Lavori -->
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Direttore dei Lavori" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                        <TextBox Text="{Binding DirettoreLavori, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                    </StackPanel>

                    <!-- Riga 4: Luogo / Comune / Provincia -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Luogo (via/piazza)" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <TextBox Text="{Binding Luogo, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Comune" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <TextBox Text="{Binding Comune, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Prov." FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <TextBox Text="{Binding Provincia, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" MaxLength="2" />
                        </StackPanel>
                    </Grid>

                    <!-- Riga 5: Date -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Data computo" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <DatePicker SelectedDate="{Binding DataComputo}" FontSize="11" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Data prezzi listino" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <DatePicker SelectedDate="{Binding DataPrezzi}" FontSize="11" />
                        </StackPanel>
                    </Grid>

                    <!-- Riga 6: Riferimento prezzario + Ribasso -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Riferimento prezzario (es. DEI 2024, Toscana 2024)" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <TextBox Text="{Binding RiferimentoPrezzario, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ribasso d'asta (%)" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <TextBox Text="{Binding RibassoPercentuale, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                        </StackPanel>
                    </Grid>

                    <!-- Riga 7: CIG + CUP -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CIG" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <TextBox Text="{Binding Cig, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11" Padding="6,4" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="CUP" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <TextBox Text="{Binding Cup, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11" Padding="6,4" />
                        </StackPanel>
                    </Grid>

                    <!-- Footer: Save + status -->
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding StatusMessage}"
                                   VerticalAlignment="Center"
                                   FontSize="10" FontStyle="Italic"
                                   Foreground="{DynamicResource InkMutedBrush}" />
                        <Button Grid.Column="1"
                                Content="⬇ Eredita da Revit"
                                Click="OnImportFromRevitClick"
                                Padding="10,4" FontSize="11"
                                Background="Transparent"
                                Foreground="{DynamicResource InkDefaultBrush}"
                                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                Margin="0,0,6,0" Cursor="Hand"
                                ToolTip="Importa i campi disponibili dai Project Information e dai parametri di progetto del modello Revit attivo" />
                        <Button Grid.Column="2"
                                Content="💾 Salva"
                                Command="{Binding SaveCommand}"
                                Padding="12,4" FontSize="11" FontWeight="SemiBold"
                                Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                                BorderThickness="0" Cursor="Hand" />
                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
