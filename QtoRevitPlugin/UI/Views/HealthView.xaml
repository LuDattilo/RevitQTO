<UserControl x:Class="QtoRevitPlugin.UI.Views.HealthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QtoRevitPlugin.UI.ViewModels">
    <UserControl.DataContext>
        <vm:HealthViewModel/>
    </UserControl.DataContext>

    <Grid Background="{DynamicResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- titolo -->
            <RowDefinition Height="Auto" />
            <!-- toolbar run -->
            <RowDefinition Height="Auto" />
            <!-- status/kpi -->
            <RowDefinition Height="*" />
            <!-- contenuto -->
        </Grid.RowDefinitions>

        <!-- Titolo -->
        <Grid Grid.Row="0" Margin="16,14,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Health Check" Style="{DynamicResource ViewTitleStyle}" />
            <TextBlock Grid.Column="1" Text="§ I5 · anomalie quantità + mismatch semantici"
                       VerticalAlignment="Bottom"
                       Foreground="{DynamicResource InkMutedBrush}"
                       FontFamily="{DynamicResource FontMono}" FontSize="10"
                       Margin="8,0,0,12" />
        </Grid>

        <!-- Toolbar "Esegui controllo" -->
        <Border Grid.Row="1" Margin="16,8,16,0" Padding="12,10"
                Background="{DynamicResource PanelSubBrush}"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           FontSize="11"
                           Foreground="{DynamicResource InkDefaultBrush}"
                           VerticalAlignment="Center" />

                <!-- Spinner testuale mentre IsRunning -->
                <TextBlock Grid.Column="1"
                           Text="◌"
                           Margin="12,0,12,0"
                           FontFamily="{DynamicResource FontMono}"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource BrandAccentBrush}"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsRunning, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}" />

                <Button Grid.Column="2"
                        Content="Esegui controllo"
                        Command="{Binding RunCommand}"
                        Padding="14,4" FontSize="11" FontWeight="SemiBold"
                        Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand" />
            </Grid>
        </Border>

        <!-- KPI riassuntivi (visibili solo dopo il primo run) -->
        <Border Grid.Row="2" Margin="16,8,16,0" Padding="10,8"
                Background="{DynamicResource ChromeBgBrush}"
                BorderBrush="{DynamicResource ChromeEdgeBrush}" BorderThickness="1"
                CornerRadius="4"
                Visibility="{Binding HasReport, Converter={x:Static vm:BoolToVisibilityConverter.Instance}, FallbackValue=Collapsed}">
            <UniformGrid Columns="4">
                <StackPanel>
                    <TextBlock Text="ASSEGNAZIONI"
                               FontFamily="{DynamicResource FontMono}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource ChromeTextDimBrush}" />
                    <TextBlock Text="{Binding AssignmentsAnalyzed}"
                               Margin="0,4,0,0"
                               FontFamily="{DynamicResource FontDisplay}"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource ChromeTextBrush}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="ANOMALIE QTÀ"
                               FontFamily="{DynamicResource FontMono}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource ChromeTextDimBrush}" />
                    <TextBlock Text="{Binding AnomaliesCount}"
                               Margin="0,4,0,0"
                               FontFamily="{DynamicResource FontDisplay}"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource ChromeTextBrush}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="MISMATCH AI"
                               FontFamily="{DynamicResource FontMono}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource ChromeTextDimBrush}" />
                    <TextBlock Text="{Binding MismatchesCount}"
                               Margin="0,4,0,0"
                               FontFamily="{DynamicResource FontDisplay}"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource ChromeTextBrush}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="AI"
                               FontFamily="{DynamicResource FontMono}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource ChromeTextDimBrush}" />
                    <TextBlock Margin="0,4,0,0"
                               FontFamily="{DynamicResource FontDisplay}"
                               FontSize="14" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Non usata" />
                                <Setter Property="Foreground" Value="{DynamicResource ChromeTextDimBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AiUsed}" Value="True">
                                        <Setter Property="Text" Value="Usata" />
                                        <Setter Property="Foreground" Value="{DynamicResource BrandAccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- Contenuto: due liste side-by-side -->
        <ScrollViewer Grid.Row="3" Margin="16,8,16,16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Empty state (nessun problema) -->
                <Border Padding="14"
                        Background="{DynamicResource BrandAccentSoftBrush}"
                        BorderBrush="{DynamicResource BrandAccentBrush}" BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{Binding HasNoIssues, Converter={x:Static vm:BoolToVisibilityConverter.Instance}, FallbackValue=Collapsed}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓"
                                   FontFamily="{DynamicResource FontMono}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource BrandAccentBrush}"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Nessun problema rilevato. Il computo è coerente."
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource InkDefaultBrush}" />
                    </StackPanel>
                </Border>

                <!-- Anomalie quantità -->
                <Border Margin="0,0,0,12"
                        Style="{DynamicResource CardStyle}"
                        Visibility="{Binding AnomaliesCount, Converter={x:Static vm:IntToVisibilityConverter.Instance}}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ANOMALIE QUANTITÀ" Style="{DynamicResource SectionLabelStyle}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AnomaliesCount, StringFormat='{}{0} problema/i'}"
                                       FontSize="10" FontStyle="Italic"
                                       Foreground="{DynamicResource InkMutedBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="Elementi con quantity molto fuori dalla media del loro gruppo EP (z-score statistico, sempre disponibile)."
                                   TextWrapping="Wrap"
                                   FontSize="10"
                                   Foreground="{DynamicResource InkMutedBrush}"
                                   Margin="0,4,0,8" />
                        <DataGrid ItemsSource="{Binding Anomalies}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="22"
                                  FontSize="10"
                                  Background="White"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource EdgeLightBrush}"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Severità" Binding="{Binding SeverityLabel}" Width="80" />
                                <DataGridTextColumn Header="EP" Binding="{Binding EpCode}" Width="140" />
                                <DataGridTextColumn Header="UniqueId" Binding="{Binding UniqueId}" Width="180" />
                                <DataGridTextColumn Header="Qtà" Binding="{Binding QuantityLabel}" Width="80" />
                                <DataGridTextColumn Header="Media" Binding="{Binding MeanLabel}" Width="80" />
                                <DataGridTextColumn Header="Z-score" Binding="{Binding ZScoreLabel}" Width="70" />
                                <DataGridTextColumn Header="Messaggio" Binding="{Binding Message}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Mismatch semantici -->
                <Border Style="{DynamicResource CardStyle}"
                        Visibility="{Binding MismatchesCount, Converter={x:Static vm:IntToVisibilityConverter.Instance}}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="MISMATCH SEMANTICI (AI)" Style="{DynamicResource SectionLabelStyle}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding MismatchesCount, StringFormat='{}{0} problema/i'}"
                                       FontSize="10" FontStyle="Italic"
                                       Foreground="{DynamicResource InkMutedBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="Assegnazioni dove categoria/famiglia Revit è semanticamente poco coerente con la descrizione EP (cosine similarity &lt; soglia)."
                                   TextWrapping="Wrap"
                                   FontSize="10"
                                   Foreground="{DynamicResource InkMutedBrush}"
                                   Margin="0,4,0,8" />
                        <DataGrid ItemsSource="{Binding Mismatches}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="22"
                                  FontSize="10"
                                  Background="White"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource EdgeLightBrush}"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Similarità" Binding="{Binding SimilarityLabel}" Width="80" />
                                <DataGridTextColumn Header="Categoria · Famiglia" Binding="{Binding CategoryFamilyLabel}" Width="200" />
                                <DataGridTextColumn Header="EP assegnato" Binding="{Binding EpCode}" Width="140" />
                                <DataGridTextColumn Header="Descrizione EP" Binding="{Binding EpDescription}" Width="*" />
                                <DataGridTextColumn Header="Alternativa" Binding="{Binding SuggestionLabel}" Width="200" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
