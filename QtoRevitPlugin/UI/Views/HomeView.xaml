<UserControl x:Class="QtoRevitPlugin.UI.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource PanelBgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="8,4,8,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="1"
                    Style="{DynamicResource CardStyle}"
                    Background="{DynamicResource ChromeBgBrush}"
                    BorderBrush="{DynamicResource ChromeEdgeBrush}"
                    Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,18,0">
                        <TextBlock Text="Home"
                                   Foreground="{DynamicResource ChromeTextBrush}"
                                   FontFamily="{DynamicResource FontDisplay}"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Avvio operativo del computo"
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource ChromeTextDimBrush}"
                                   FontFamily="{DynamicResource FontMono}"
                                   FontSize="10" />

                        <TextBlock Text="{Binding HomePrimaryMessage}"
                                   Margin="0,18,0,0"
                                   Foreground="{DynamicResource BrandAccentSoftBrush}"
                                   FontFamily="{DynamicResource FontDisplay}"
                                   FontSize="16" />
                        <TextBlock Text="{Binding HomeSecondaryMessage}"
                                   Margin="0,10,0,0"
                                   Foreground="{DynamicResource ChromeTextBrush}"
                                   TextWrapping="Wrap" />

                        <WrapPanel Margin="0,18,0,0">
                            <Button Content="Nuovo computo"
                                    Style="{DynamicResource BtnPrimary}"
                                    Margin="0,0,10,10"
                                    Click="OnNewSessionClick" />
                            <Button Content="Apri computo"
                                    Style="{DynamicResource BtnSecondary}"
                                    Margin="0,0,10,10"
                                    Click="OnOpenSessionClick" />
                            <Button Content="Riprendi ultimo"
                                    Style="{DynamicResource BtnSecondary}"
                                    Margin="0,0,0,10"
                                    IsEnabled="{Binding CanResumeLastSession}"
                                    Click="OnResumeLastClick" />
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Border Background="#221C1917"
                                BorderBrush="{DynamicResource ChromeEdgeBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="Ultimo computo"
                                           Foreground="{DynamicResource ChromeTextDimBrush}"
                                           FontFamily="{DynamicResource FontMono}"
                                           FontSize="9" />
                                <TextBlock Text="{Binding LastSessionHint}"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource ChromeTextBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0"
                                Background="#221C1917"
                                BorderBrush="{DynamicResource ChromeEdgeBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="Vincoli di flusso"
                                           Foreground="{DynamicResource ChromeTextDimBrush}"
                                           FontFamily="{DynamicResource FontMono}"
                                           FontSize="9" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="Il Listino precede la Selezione. La fase Revit viene gestita dentro Selezione e aggiorna le viste phase-bound con soft switch."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource ChromeTextBrush}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2"
                       Margin="0,18,0,8"
                       Text="WORKFLOW"
                       Foreground="{DynamicResource BrandAccentBrush}"
                       FontFamily="{DynamicResource FontMono}"
                       FontSize="9"
                       FontWeight="Bold" />

            <Border Grid.Row="3"
                    Style="{DynamicResource CardStyle}"
                    Padding="16">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding HomeWorkflowSteps}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource PanelSubBrush}"
                                        BorderBrush="{DynamicResource EdgeLightBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,10"
                                        Margin="0,0,10,10">
                                    <TextBlock Text="{Binding}"
                                               Foreground="{DynamicResource InkDefaultBrush}"
                                               FontWeight="SemiBold" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
