<UserControl x:Class="QtoRevitPlugin.UI.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource PanelBgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16,14,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Home"
                               Style="{DynamicResource ViewTitleStyle}" />
                    <TextBlock Text="Avvio operativo del computo"
                               Margin="0,2,0,0"
                               Foreground="{DynamicResource InkMutedBrush}"
                               FontFamily="{DynamicResource FontMono}"
                               FontSize="10" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{DynamicResource PanelSubBrush}"
                        BorderBrush="{DynamicResource EdgeLightBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,6"
                        VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Ultimo computo"
                                   Foreground="{DynamicResource InkMutedBrush}"
                                   FontFamily="{DynamicResource FontMono}"
                                   FontSize="9" />
                        <TextBlock Text="{Binding LastSessionHint}"
                                   Foreground="{DynamicResource InkBrush}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,14,0,0"
                    Style="{DynamicResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding HomePrimaryMessage}"
                               Style="{DynamicResource SectionLabelStyle}" />
                    <TextBlock Text="{Binding HomeSecondaryMessage}"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource InkDimBrush}"
                               TextWrapping="Wrap" />

                    <UniformGrid Columns="3" Margin="0,14,0,0">
                        <Button Content="Nuovo computo"
                                Margin="0,0,8,0"
                                Click="OnNewSessionClick" />
                        <Button Content="Apri computo"
                                Margin="0,0,8,0"
                                Click="OnOpenSessionClick" />
                        <Button Content="Riprendi ultimo"
                                IsEnabled="{Binding CanResumeLastSession}"
                                Click="OnResumeLastClick" />
                    </UniformGrid>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2"
                       Margin="0,18,0,8"
                       Text="WORKFLOW"
                       Foreground="{DynamicResource BrandAccentBrush}"
                       FontFamily="{DynamicResource FontMono}"
                       FontSize="9"
                       FontWeight="Bold" />

            <ItemsControl Grid.Row="3"
                          ItemsSource="{Binding HomeWorkflowSteps}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource PanelSubBrush}"
                                BorderBrush="{DynamicResource EdgeLightBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,10,10">
                            <TextBlock Text="{Binding}"
                                       Foreground="{DynamicResource InkBrush}"
                                       FontWeight="SemiBold" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="4"
                    Margin="0,8,0,0"
                    Background="{DynamicResource PanelSubBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,12">
                <StackPanel>
                    <TextBlock Text="Vincoli di flusso"
                               Style="{DynamicResource SectionLabelStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Il Listino precede la Selezione. La fase Revit viene gestita dentro Selezione e aggiorna le viste phase-bound con soft switch."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource InkDimBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
