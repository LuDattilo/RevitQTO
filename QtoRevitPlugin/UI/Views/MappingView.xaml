<UserControl x:Class="QtoRevitPlugin.UI.Views.MappingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:QtoRevitPlugin.Models;assembly=QtoRevitPlugin.Core">

    <Grid Background="{DynamicResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- =================================================================== -->
        <!-- Titolo view                                                        -->
        <!-- =================================================================== -->
        <Grid Grid.Row="0" Margin="16,14,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Mapping Sorgenti" Style="{DynamicResource ViewTitleStyle}" />
            <TextBlock Grid.Column="1" Text="§ Sprint 4 · Task 3"
                       VerticalAlignment="Bottom"
                       Foreground="{DynamicResource InkMutedBrush}"
                       FontFamily="{DynamicResource FontMono}" FontSize="10"
                       Margin="8,0,0,12" />
            <Button Grid.Column="3" x:Name="BtnPopout" Click="OnPopoutClick"
                    Content="⤢ Apri in finestra"
                    Padding="8,3" FontSize="10"
                    Background="Transparent" Foreground="{DynamicResource InkDimBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    ToolTip="Apre questa scheda in una finestra separata" />
        </Grid>

        <!-- =================================================================== -->
        <!-- TabControl con 3 tab (Famiglie / Locali / Manuali)                 -->
        <!-- =================================================================== -->
        <TabControl Grid.Row="1" Margin="16,4,16,4"
                    SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}"
                    Background="{DynamicResource PanelBgBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}"
                    BorderThickness="1"
                    Padding="0">

            <!-- ============================================================ -->
            <!-- TAB 1 — FAMIGLIE (Sorgente A)                                -->
            <!-- ============================================================ -->
            <TabItem Header="Famiglie">
                <Grid Background="{DynamicResource PanelBgBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header sezione -->
                    <Border Grid.Row="0" Margin="12,12,12,4" Padding="12,8"
                            Background="{DynamicResource BrandAccentSoftBrush}"
                            CornerRadius="3">
                        <TextBlock FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource InkDefaultBrush}"
                                   Text="SORGENTE A · Famiglie Revit → Voce EP. Preview read-only delle aggregazioni FamilyType. L'assegnazione effettiva EP → famiglia avverrà nello Sprint 5 (Tagging)." />
                    </Border>

                    <!-- Filtro categoria + toolbar -->
                    <Border Grid.Row="1" Style="{DynamicResource CardStyle}" Margin="12,4,12,4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="CATEGORIA" Style="{DynamicResource SectionLabelStyle}" />
                            <Grid Grid.Row="1" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Categoria Revit:" Margin="0,0,8,0"
                                           VerticalAlignment="Center" FontSize="11" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding FamilyCategories}"
                                          SelectedItem="{Binding SelectedFamilyCategory, Mode=TwoWay}"
                                          DisplayMemberPath="Label"
                                          FontSize="11" Padding="6,3" />
                                <StackPanel Grid.Column="3" Orientation="Horizontal">
                                    <Button x:Name="BtnRefreshFamilies" Click="OnRefreshFamiliesClick"
                                            Content="Aggiorna"
                                            Padding="10,4" FontSize="11"
                                            Background="Transparent"
                                            Foreground="{DynamicResource InkDefaultBrush}"
                                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                            Cursor="Hand" />
                                    <Button x:Name="BtnAssignEp" Click="OnAssignEpClick"
                                            Content="Assegna EP…"
                                            Margin="6,0,0,0" Padding="10,4" FontSize="11" FontWeight="SemiBold"
                                            Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                                            BorderThickness="0" Cursor="Hand" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- DataGrid famiglie aggregate -->
                    <Border Grid.Row="3" Margin="12,4,12,4"
                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1">
                        <DataGrid x:Name="GridFamilies"
                                  ItemsSource="{Binding FamilyTypes}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="22"
                                  FontSize="11"
                                  Background="White"
                                  BorderThickness="0"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Famiglia"       Binding="{Binding Family}"         Width="*" />
                                <DataGridTextColumn Header="Tipo"           Binding="{Binding Type}"           Width="*" />
                                <DataGridTextColumn Header="N° istanze"     Binding="{Binding InstanceCount}"  Width="90"  FontFamily="Consolas" />
                                <DataGridTextColumn Header="EP assegnato"   Binding="{Binding AssignedEp}"     Width="110" FontFamily="Consolas" />
                                <DataGridTextColumn Header="Prezzo stimato" Binding="{Binding EstimatedPrice}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Status bar tab -->
                    <Border Grid.Row="4" Background="{DynamicResource PanelSubBrush}"
                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="0,1,0,0"
                            Padding="12,8">
                        <TextBlock Text="{Binding FamilyStatus}"
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource InkMutedBrush}" />
                    </Border>
                </Grid>
            </TabItem>

            <!-- ============================================================ -->
            <!-- TAB 2 — LOCALI (Sorgente B)                                  -->
            <!-- ============================================================ -->
            <TabItem Header="Locali">
                <Grid Background="{DynamicResource PanelBgBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header sezione -->
                    <Border Grid.Row="0" Margin="12,12,12,4" Padding="12,8"
                            Background="{DynamicResource BrandAccentSoftBrush}"
                            CornerRadius="3">
                        <TextBlock FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource InkDefaultBrush}"
                                   Text="SORGENTE B · Room / MEP Space → formula NCalc. Identificatori disponibili: Area, Perimeter, Volume, Height (da QTO_AltezzaLocale), più qualsiasi parametro di progetto/shared letto via LookupParameter. Persistenza in-memory per ora · save DB → Sprint 5." />
                    </Border>

                    <!-- Toolbar -->
                    <Border Grid.Row="1" Margin="12,4,12,4" Padding="0">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnAddRoomMapping" Click="OnAddRoomMappingClick"
                                    Content="+ Nuova formula…"
                                    Padding="10,4" FontSize="11" FontWeight="SemiBold"
                                    Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" />
                            <Button x:Name="BtnEditRoomMapping" Click="OnEditRoomMappingClick"
                                    Content="Modifica"
                                    Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                    Background="Transparent"
                                    Foreground="{DynamicResource InkDefaultBrush}"
                                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                    Cursor="Hand" />
                            <Button x:Name="BtnDeleteRoomMapping" Click="OnDeleteRoomMappingClick"
                                    Content="Elimina"
                                    Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                    Background="Transparent"
                                    Foreground="{DynamicResource InkDefaultBrush}"
                                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                    Cursor="Hand" />
                        </StackPanel>
                    </Border>

                    <!-- Split verticale: lista formule (top) + editor card (bottom collapsible) -->
                    <Grid Grid.Row="2" Margin="12,4,12,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="120" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- DataGrid formule esistenti -->
                        <Border Grid.Row="0"
                                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1">
                            <DataGrid x:Name="GridRoomMappings"
                                      ItemsSource="{Binding RoomMappings}"
                                      SelectedItem="{Binding SelectedRoomMapping, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeight="22"
                                      FontSize="11"
                                      Background="White"
                                      BorderThickness="0"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Codice EP"    Binding="{Binding EpCode}"            Width="110" FontFamily="Consolas" />
                                    <DataGridTextColumn Header="Descrizione" Binding="{Binding EpDescription}"     Width="*" />
                                    <DataGridTextColumn Header="UM"          Binding="{Binding Unit}"              Width="50" />
                                    <DataGridTextColumn Header="Formula"     Binding="{Binding Formula}"           Width="*"   FontFamily="Consolas" />
                                    <DataGridTextColumn Header="Target"      Binding="{Binding TargetCategoryLabel}" Width="90" />
                                    <DataGridTextColumn Header="Filtro nome" Binding="{Binding RoomNameFilter}"    Width="110" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Editor card (visibile solo se EditingRoomMapping != null) -->
                        <Border Grid.Row="1" Margin="0,8,0,0" Padding="12"
                                Background="White"
                                BorderBrush="{DynamicResource BrandAccentBrush}" BorderThickness="2"
                                CornerRadius="3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EditingRoomMapping}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel DataContext="{Binding EditingRoomMapping}">
                                <TextBlock Text="EDITOR FORMULA" Style="{DynamicResource SectionLabelStyle}" />

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Codice EP:" Margin="0,0,6,0"
                                               VerticalAlignment="Center" FontSize="11" />
                                    <TextBox Grid.Column="1" Text="{Binding EpCode, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas" FontSize="11" Padding="6,3"
                                             Background="White"
                                             BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
                                    <TextBlock Grid.Column="2" Text="Descrizione:" Margin="12,0,6,0"
                                               VerticalAlignment="Center" FontSize="11" />
                                    <TextBox Grid.Column="3" Text="{Binding EpDescription, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="11" Padding="6,3"
                                             Background="White"
                                             BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
                                    <TextBlock Grid.Column="4" Text="UM:" Margin="12,0,6,0"
                                               VerticalAlignment="Center" FontSize="11" />
                                    <TextBox Grid.Column="5" Text="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="11" Padding="6,3"
                                             Background="White"
                                             BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Formula:" Margin="0,0,6,0"
                                               VerticalAlignment="Top" FontSize="11" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Formula, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas" FontSize="12" Padding="6,3"
                                             Background="White"
                                             BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                             ToolTip="Esempi: Area · Perimeter - LargTotAperture · Perimeter * H_Controsoffitto · Volume · Area * 1.08" />
                                </Grid>

                                <TextBlock Margin="0,4,0,0"
                                           FontSize="10" FontStyle="Italic"
                                           Foreground="{DynamicResource InkMutedBrush}"
                                           Text="Esempi: Area · Perimeter - LargTotAperture · Perimeter * H_Controsoffitto · Volume · Area * 1.08" />

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Target:" Margin="0,0,6,0"
                                               VerticalAlignment="Center" FontSize="11" />
                                    <ComboBox Grid.Column="1"
                                              x:Name="CbTargetCategory"
                                              SelectedValuePath="Tag"
                                              SelectedValue="{Binding TargetCategory, Mode=TwoWay}"
                                              FontSize="11" Padding="6,3">
                                        <ComboBoxItem Content="Rooms">
                                            <ComboBoxItem.Tag>
                                                <models:RoomTargetCategory>Rooms</models:RoomTargetCategory>
                                            </ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="MEP Spaces">
                                            <ComboBoxItem.Tag>
                                                <models:RoomTargetCategory>MEPSpaces</models:RoomTargetCategory>
                                            </ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="Filtro nome Room (opz.):" Margin="12,0,6,0"
                                               VerticalAlignment="Center" FontSize="11" />
                                    <TextBox Grid.Column="3"
                                             Text="{Binding RoomNameFilter, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="11" Padding="6,3"
                                             Background="White"
                                             BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                             ToolTip="Filtra Room per sottostringa case-insensitive. Vuoto = tutti." />
                                </Grid>

                                <!-- Risultato test formula -->
                                <Border Margin="0,8,0,0" Padding="8,6"
                                        Background="{DynamicResource PanelSubBrush}"
                                        BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.RoomTestResult, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontFamily="{DynamicResource FontMono}" FontSize="11"
                                               Foreground="{DynamicResource InkDefaultBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding DataContext.RoomTestResult, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                </Border>

                                <!-- Toolbar card: test / salva / annulla -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                            HorizontalAlignment="Right">
                                    <Button x:Name="BtnTestFormula" Click="OnTestFormulaClick"
                                            Content="Test formula…"
                                            Padding="10,4" FontSize="11"
                                            Background="Transparent"
                                            Foreground="{DynamicResource InkDefaultBrush}"
                                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                            Cursor="Hand" />
                                    <Button x:Name="BtnCancelRoomMapping" Click="OnCancelRoomMappingClick"
                                            Content="Annulla"
                                            Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                            Background="Transparent"
                                            Foreground="{DynamicResource InkDimBrush}"
                                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                            Cursor="Hand" />
                                    <Button x:Name="BtnSaveRoomMapping" Click="OnSaveRoomMappingClick"
                                            Content="Salva"
                                            Margin="6,0,0,0" Padding="12,4" FontSize="11" FontWeight="SemiBold"
                                            Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                                            BorderThickness="0" Cursor="Hand" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Status bar tab -->
                    <Border Grid.Row="4" Background="{DynamicResource PanelSubBrush}"
                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="0,1,0,0"
                            Padding="12,8">
                        <TextBlock Text="{Binding RoomStatus}"
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource InkMutedBrush}" />
                    </Border>
                </Grid>
            </TabItem>

            <!-- ============================================================ -->
            <!-- TAB 3 — VOCI MANUALI (Sorgente C)                            -->
            <!-- ============================================================ -->
            <TabItem Header="Voci manuali">
                <Grid Background="{DynamicResource PanelBgBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header sezione -->
                    <Border Grid.Row="0" Margin="12,12,12,4" Padding="12,8"
                            Background="{DynamicResource BrandAccentSoftBrush}"
                            CornerRadius="3">
                        <TextBlock FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource InkDefaultBrush}"
                                   Text="SORGENTE C · Voci manuali (lavorazioni non modellabili). Oneri sicurezza, ponteggi, smaltimento, manodopera oraria, pulizie a corpo. Persistenza in-memory per ora · save DB → Sprint 5." />
                    </Border>

                    <!-- Toolbar -->
                    <Border Grid.Row="1" Margin="12,4,12,4">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnAddManualItem" Click="OnAddManualItemClick"
                                    Content="+ Nuova voce manuale…"
                                    Padding="10,4" FontSize="11" FontWeight="SemiBold"
                                    Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" />
                            <Button x:Name="BtnEditManualItem" Click="OnEditManualItemClick"
                                    Content="Modifica"
                                    Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                    Background="Transparent"
                                    Foreground="{DynamicResource InkDefaultBrush}"
                                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                    Cursor="Hand" />
                            <Button x:Name="BtnDuplicateManualItem" Click="OnDuplicateManualItemClick"
                                    Content="Duplica"
                                    Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                    Background="Transparent"
                                    Foreground="{DynamicResource InkDefaultBrush}"
                                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                    Cursor="Hand" />
                            <Button x:Name="BtnDeleteManualItem" Click="OnDeleteManualItemClick"
                                    Content="Elimina"
                                    Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                    Background="Transparent"
                                    Foreground="{DynamicResource InkDefaultBrush}"
                                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                    Cursor="Hand" />
                        </StackPanel>
                    </Border>

                    <!-- DataGrid voci -->
                    <Border Grid.Row="2" Margin="12,4,12,4"
                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1">
                        <DataGrid x:Name="GridManualItems"
                                  ItemsSource="{Binding ManualItems}"
                                  SelectedItem="{Binding SelectedManualItem, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="22"
                                  FontSize="11"
                                  Background="White"
                                  BorderThickness="0"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Codice EP"      Binding="{Binding EpCode}"              Width="120" FontFamily="Consolas" />
                                <DataGridTextColumn Header="Descrizione"   Binding="{Binding EpDescription}"       Width="*" />
                                <DataGridTextColumn Header="UM"            Binding="{Binding Unit}"                Width="60" />
                                <DataGridTextColumn Header="Quantità"      Binding="{Binding Quantity}"            Width="80"  FontFamily="Consolas" />
                                <DataGridTextColumn Header="Prezzo Unit."  Binding="{Binding UnitPriceFormatted}"  Width="100" FontFamily="Consolas" />
                                <DataGridTextColumn Header="Totale"        Binding="{Binding TotalFormatted}"      Width="100" FontFamily="Consolas" FontWeight="SemiBold" />
                                <DataGridTextColumn Header="Note"          Binding="{Binding Notes}"               Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Editor card voci manuali -->
                    <Border Grid.Row="3" Margin="12,4,12,4" Padding="12"
                            Background="White"
                            BorderBrush="{DynamicResource BrandAccentBrush}" BorderThickness="2"
                            CornerRadius="3">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EditingManualItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel DataContext="{Binding EditingManualItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="EDITOR VOCE MANUALE" Style="{DynamicResource SectionLabelStyle}" />
                                <Button Grid.Column="1"
                                        x:Name="BtnLookupUserLibrary" Click="OnLookupUserLibraryClick"
                                        Content="Cerca nella UserLibrary…"
                                        Padding="8,2" FontSize="10"
                                        Background="Transparent"
                                        Foreground="{DynamicResource InkDefaultBrush}"
                                        BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                        Cursor="Hand"
                                        ToolTip="Apre un mini-dialog per cercare una voce EP nei listini e auto-compilare codice/descrizione/UM/prezzo." />
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Codice EP:" Margin="0,0,6,0"
                                           VerticalAlignment="Center" FontSize="11" />
                                <TextBox Grid.Column="1" Text="{Binding EpCode, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas" FontSize="11" Padding="6,3"
                                         Background="White"
                                         BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
                                <TextBlock Grid.Column="2" Text="Descrizione:" Margin="12,0,6,0"
                                           VerticalAlignment="Center" FontSize="11" />
                                <TextBox Grid.Column="3" Text="{Binding EpDescription, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="11" Padding="6,3"
                                         Background="White"
                                         BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
                                <TextBlock Grid.Column="4" Text="UM:" Margin="12,0,6,0"
                                           VerticalAlignment="Center" FontSize="11" />
                                <TextBox Grid.Column="5" Text="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="11" Padding="6,3"
                                         Background="White"
                                         BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Quantità:" Margin="0,0,6,0"
                                           VerticalAlignment="Center" FontSize="11" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"
                                         FontFamily="Consolas" FontSize="11" Padding="6,3"
                                         Background="White"
                                         BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
                                <TextBlock Grid.Column="2" Text="Prezzo Unit.:" Margin="12,0,6,0"
                                           VerticalAlignment="Center" FontSize="11" />
                                <TextBox Grid.Column="3"
                                         Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                         FontFamily="Consolas" FontSize="11" Padding="6,3"
                                         Background="White"
                                         BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
                                <TextBlock Grid.Column="4" Text="Note:" Margin="12,0,6,0"
                                           VerticalAlignment="Center" FontSize="11" />
                                <TextBox Grid.Column="5" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="11" Padding="6,3"
                                         Background="White"
                                         BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1" />
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                        HorizontalAlignment="Right">
                                <TextBlock VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource InkMutedBrush}"
                                           Text="{Binding TotalFormatted, StringFormat='Totale riga: {0}'}" />
                                <Button x:Name="BtnCancelManualItem" Click="OnCancelManualItemClick"
                                        Content="Annulla"
                                        Padding="10,4" FontSize="11"
                                        Background="Transparent"
                                        Foreground="{DynamicResource InkDimBrush}"
                                        BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                        Cursor="Hand" />
                                <Button x:Name="BtnSaveManualItem" Click="OnSaveManualItemClick"
                                        Content="Salva"
                                        Margin="6,0,0,0" Padding="12,4" FontSize="11" FontWeight="SemiBold"
                                        Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                                        BorderThickness="0" Cursor="Hand" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Footer totale -->
                    <Border Grid.Row="4" Margin="12,4,12,0" Padding="12,8"
                            Background="{DynamicResource PanelSubBrush}"
                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                            CornerRadius="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="TOTALE VOCI MANUALI"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource InkDimBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ManualTotal, StringFormat='€ {0:N2}'}"
                                       FontFamily="{DynamicResource FontMono}" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource BrandAccentDeepBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Status bar tab -->
                    <Border Grid.Row="5" Background="{DynamicResource PanelSubBrush}"
                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="0,1,0,0"
                            Padding="12,8" Margin="0,4,0,0">
                        <TextBlock Text="{Binding ManualStatus}"
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource InkMutedBrush}" />
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- =================================================================== -->
        <!-- Footer globale                                                     -->
        <!-- =================================================================== -->
        <Border Grid.Row="2" Background="{DynamicResource PanelSubBrush}"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock FontSize="10"
                       Foreground="{DynamicResource InkMutedBrush}"
                       TextWrapping="Wrap"
                       Text="• Persistenza DB di formule Room e voci manuali → Sprint 5 (insieme al flow tagging completo)  •  Assegnazione EP reale alle famiglie (multi-EP, scrittura parametri QTO) → Sprint 5" />
        </Border>
    </Grid>
</UserControl>
