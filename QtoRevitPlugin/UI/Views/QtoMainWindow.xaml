<Window x:Class="QtoRevitPlugin.UI.Views.QtoMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QtoRevitPlugin.UI.ViewModels"
        Title="QTO – Computo Metrico Estimativo"
        Height="720" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1F4E79" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="QTO – Computo Metrico Estimativo"
                               Foreground="White" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SessionTitle}"
                               Foreground="#BDD7EE" FontSize="11" Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ProgressText}"
                               Foreground="#BDD7EE" FontSize="11" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding TotalAmount, StringFormat='€ {0:N2}'}"
                               Foreground="White" FontSize="13" FontWeight="Bold" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Contenuto principale — placeholder Sprint 0 -->
        <Border Grid.Row="1" Margin="24" Background="White" CornerRadius="4"
                BorderBrush="#CCCCCC" BorderThickness="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6">
                <TextBlock Text="QTO Plugin" FontSize="32" FontWeight="Light"
                           HorizontalAlignment="Center" Foreground="#1F4E79" />
                <TextBlock Text="Sprint 0 – Fondamenta" FontSize="14"
                           HorizontalAlignment="Center" Foreground="#666" Margin="0,8,0,0" />
                <TextBlock Text="Il pannello operativo sarà disponibile dallo Sprint 1"
                           FontSize="11" HorizontalAlignment="Center"
                           Foreground="#888" Margin="0,4,0,0" />
                <Button Content="Nuova Sessione"
                        Command="{Binding NewSessionCommand}"
                        Margin="0,24,0,0" Padding="16,8"
                        HorizontalAlignment="Center"
                        Background="#1F4E79" Foreground="White"
                        BorderThickness="0" FontSize="12" />
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#E8E8E8" BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0" Padding="12,5">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11" Foreground="#555" />
        </Border>
    </Grid>
</Window>
