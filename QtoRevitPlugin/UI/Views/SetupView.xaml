<UserControl x:Class="QtoRevitPlugin.UI.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{DynamicResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═════════════════════════════════════════════════════════════ -->
        <!-- Titolo view                                                   -->
        <!-- ═════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="16,14,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Setup" Style="{DynamicResource ViewTitleStyle}" />
            <TextBlock Grid.Column="1" Text="§ Fase 1"
                       VerticalAlignment="Bottom"
                       Foreground="{DynamicResource InkMutedBrush}"
                       FontFamily="{DynamicResource FontMono}" FontSize="10"
                       Margin="8,0,0,12" />
            <Button Grid.Column="3" x:Name="BtnPopout" Click="OnPopoutClick"
                    Content="⤢ Apri in finestra"
                    Padding="8,3" FontSize="10"
                    Background="Transparent" Foreground="{DynamicResource InkDimBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    ToolTip="Apre questa scheda in una finestra separata per workflow multi-monitor" />
        </Grid>

        <!-- ═════════════════════════════════════════════════════════════ -->
        <!-- Listini caricati + toolbar                                    -->
        <!-- ═════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{DynamicResource CardStyle}" Margin="16,8,16,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header sezione + toolbar -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="LISTINI IN LIBRERIA (PERSISTENTI · CONDIVISI TRA COMPUTI)"
                               Style="{DynamicResource SectionLabelStyle}"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnImport" Click="OnImportClick"
                                Content="+ Importa listino…"
                                Padding="10,4" FontSize="11" FontWeight="SemiBold"
                                Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                                BorderThickness="0" Cursor="Hand" />
                        <Button x:Name="BtnBrowse" Click="OnBrowseCatalogClick"
                                Content="Sfoglia listino…"
                                Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                Background="Transparent"
                                Foreground="{DynamicResource InkDefaultBrush}"
                                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                Cursor="Hand"
                                ToolTip="Apri finestra con albero gerarchico completo del listino" />
                        <Button x:Name="BtnDelete" Click="OnDeleteClick"
                                Content="Elimina"
                                Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                Background="Transparent"
                                Foreground="{DynamicResource InkDefaultBrush}"
                                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                Cursor="Hand" />
                    </StackPanel>
                </Grid>

                <!-- DataGrid listini -->
                <DataGrid Grid.Row="1" x:Name="GridPriceLists"
                          Margin="0,8,0,0"
                          Height="140"
                          ItemsSource="{Binding PriceLists}"
                          SelectedItem="{Binding SelectedPriceList, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeight="24"
                          FontSize="11"
                          Background="White"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource EdgeLightBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nome"     Binding="{Binding Name}"           Width="*" />
                        <DataGridTextColumn Header="Sorgente" Binding="{Binding Source}"         Width="70" />
                        <DataGridTextColumn Header="Regione"  Binding="{Binding Region}"         Width="80" />
                        <DataGridTextColumn Header="Voci"     Binding="{Binding RowCount}"       Width="60" />
                        <DataGridTextColumn Header="Prio"     Binding="{Binding Priority}"       Width="40" />
                        <DataGridCheckBoxColumn Header="Attivo" Binding="{Binding IsActive}"     Width="50" />
                        <DataGridTextColumn Header="Importato" Binding="{Binding ImportedAtShort}" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Stato listini -->
                <TextBlock Grid.Row="2" Margin="0,6,0,0"
                           Text="{Binding StatusMessage}"
                           FontSize="10" FontStyle="Italic"
                           Foreground="{DynamicResource InkMutedBrush}" />
            </Grid>
        </Border>

        <!-- ═════════════════════════════════════════════════════════════ -->
        <!-- Ricerca voci EP                                               -->
        <!-- ═════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Style="{DynamicResource CardStyle}" Margin="16,0,16,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header sezione -->
                <TextBlock Grid.Row="0"
                           Text="RICERCA VOCI (CODICE ESATTO → FTS5 → FUZZY)"
                           Style="{DynamicResource SectionLabelStyle}" />

                <!-- TextBox ricerca -->
                <Grid Grid.Row="1" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             x:Name="SearchBox"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13"
                             Padding="8,6"
                             BorderBrush="{DynamicResource EdgeLightBrush}"
                             BorderThickness="1"
                             Background="White" />
                    <Border Grid.Column="1"
                            Background="{DynamicResource PanelSubBrush}"
                            BorderBrush="{DynamicResource EdgeLightBrush}"
                            BorderThickness="0,1,1,1"
                            Padding="8,6"
                            MinWidth="80">
                        <TextBlock Text="{Binding LastSearchLevel}"
                                   FontFamily="{DynamicResource FontMono}" FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource BrandAccentDeepBrush}" />
                    </Border>
                </Grid>

                <!-- Split verticale: DataGrid risultati (top) + detail panel (bottom) -->
                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" MinHeight="100" />
                        <RowDefinition Height="3" />
                        <RowDefinition Height="*" MinHeight="100" />
                    </Grid.RowDefinitions>

                    <!-- DataGrid risultati -->
                    <DataGrid Grid.Row="0" x:Name="GridResults"
                              ItemsSource="{Binding SearchResults}"
                              SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="24"
                              FontSize="11"
                              Background="White"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource EdgeLightBrush}"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Codice"      Binding="{Binding Code}"              Width="130" FontFamily="Consolas" />
                            <DataGridTextColumn Header="Descrizione" Binding="{Binding ShortDescTrimmed}"  Width="*" />
                            <DataGridTextColumn Header="U.M."        Binding="{Binding Unit}"              Width="50" />
                            <DataGridTextColumn Header="Prezzo"      Binding="{Binding UnitPriceFormatted}" Width="80" />
                            <DataGridTextColumn Header="Listino"     Binding="{Binding ListName}"          Width="100" FontSize="10" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Splitter per ridimensionare -->
                    <GridSplitter Grid.Row="1"
                                  Height="3"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="{DynamicResource EdgeLightBrush}"
                                  ShowsPreview="False"
                                  Cursor="SizeNS" />

                    <!-- Detail panel: descrizione estesa della riga selezionata -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource PanelSubBrush}"
                            BorderBrush="{DynamicResource EdgeLightBrush}"
                            BorderThickness="1"
                            DataContext="{Binding SelectedSearchResult}">
                        <Grid>
                            <!-- Placeholder quando niente è selezionato -->
                            <TextBlock x:Name="DetailPlaceholder"
                                       Text="Seleziona una voce per vedere la descrizione estesa"
                                       FontSize="11" FontStyle="Italic"
                                       Foreground="{DynamicResource InkMutedBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Contenuto detail: codice + gerarchia + descrizione full -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,8">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>
                                <StackPanel>
                                    <!-- Header: codice + listino + prezzo -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Code}"
                                                   FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource BrandAccentDeepBrush}" />
                                        <TextBlock Grid.Column="1" Margin="10,0,10,0"
                                                   Text="{Binding ListName}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource InkMutedBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding UnitPriceFormatted}"
                                                   FontFamily="{DynamicResource FontMono}" FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrandAccentDeepBrush}" />
                                    </Grid>

                                    <!-- Gerarchia breadcrumb -->
                                    <TextBlock Text="{Binding HierarchyPath}"
                                               Margin="0,4,0,0"
                                               FontSize="10"
                                               Foreground="{DynamicResource InkMutedBrush}"
                                               TextWrapping="Wrap" />

                                    <!-- Separatore sottile -->
                                    <Border Height="1" Margin="0,6,0,6"
                                            Background="{DynamicResource EdgeLightBrush}" />

                                    <!-- Descrizione full -->
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11"
                                               LineHeight="16"
                                               Foreground="{DynamicResource InkDefaultBrush}"
                                               TextWrapping="Wrap" />

                                    <!-- UM inline -->
                                    <Border Margin="0,8,0,0" Padding="6,2"
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource BrandAccentSoftBrush}"
                                            CornerRadius="2">
                                        <TextBlock Text="{Binding Unit, StringFormat='U.M.: {0}'}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrandAccentDeepBrush}" />
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Stato ricerca -->
                <TextBlock Grid.Row="3" Margin="0,6,0,0"
                           Text="{Binding SearchStatus}"
                           FontSize="10" FontStyle="Italic"
                           Foreground="{DynamicResource InkMutedBrush}" />
            </Grid>
        </Border>

        <!-- ═════════════════════════════════════════════════════════════ -->
        <!-- Footer: placeholder Sprint 6 (regole misurazione)             -->
        <!-- ═════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="{DynamicResource PanelSubBrush}"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="0,1,0,0"
                Padding="16,8" Margin="0,0,0,0">
            <TextBlock FontSize="10"
                       Foreground="{DynamicResource InkMutedBrush}"
                       TextWrapping="Wrap"
                       Text="• Regole di misurazione (vuoto per pieno, deduzioni aperture) → Sprint 6  •  Altezza locali QTO_AltezzaLocale per Sorgente B → Sprint 3 (param shared già pronto)" />
        </Border>
    </Grid>
</UserControl>
