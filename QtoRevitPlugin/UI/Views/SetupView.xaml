<UserControl x:Class="QtoRevitPlugin.UI.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QtoRevitPlugin.UI.ViewModels"
             xmlns:views="clr-namespace:QtoRevitPlugin.UI.Views">

    <Grid Background="{DynamicResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═════════════════════════════════════════════════════════════ -->
        <!-- Titolo view                                                   -->
        <!-- ═════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="16,14,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Setup" Style="{DynamicResource ViewTitleStyle}" />
            <TextBlock Grid.Column="1" Text="§ Fase 1"
                       VerticalAlignment="Bottom"
                       Foreground="{DynamicResource InkMutedBrush}"
                       FontFamily="{DynamicResource FontMono}" FontSize="10"
                       Margin="8,0,0,12" />
            <Button Grid.Column="3" x:Name="BtnPopout" Click="OnPopoutClick"
                    Content="⤢ Apri in finestra"
                    Padding="8,3" FontSize="10"
                    Background="Transparent" Foreground="{DynamicResource InkDimBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    ToolTip="Apre questa scheda in una finestra separata per workflow multi-monitor" />
        </Grid>

        <!-- ═════════════════════════════════════════════════════════════ -->
        <!-- Contenuto scrollabile: 4 sezioni (CardStyle coerente)         -->
        <!-- ═════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- ───────────────────────────────────────────────────── -->
                <!-- § 1. INFORMAZIONI PROGETTO                            -->
                <!-- ───────────────────────────────────────────────────── -->
                <Border Style="{DynamicResource CardStyle}" Margin="16,8,16,8"
                        DataContext="{Binding ProjectInfo}">
                    <StackPanel>
                        <TextBlock Text="INFORMAZIONI PROGETTO (PERSISTITE NEL .CME)"
                                   Style="{DynamicResource SectionLabelStyle}" />

                        <!-- Riga 1: Denominazione Opera + Committente -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Denominazione opera" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                                <TextBox Text="{Binding DenominazioneOpera, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Committente" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                                <TextBox Text="{Binding Committente, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                            </StackPanel>
                        </Grid>

                        <!-- Riga 2: Impresa + RUP -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Impresa appaltatrice" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                                <TextBox Text="{Binding Impresa, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Responsabile Unico del Procedimento (RUP)" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                                <TextBox Text="{Binding Rup, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                            </StackPanel>
                        </Grid>

                        <!-- Riga 3: Direttore Lavori -->
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Direttore dei Lavori" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                            <TextBox Text="{Binding DirettoreLavori, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                        </StackPanel>

                        <!-- Riga 4: Luogo / Comune / Provincia -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Luogo (via/piazza)" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                                <TextBox Text="{Binding Luogo, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Comune" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                                <TextBox Text="{Binding Comune, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Prov." FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                                <TextBox Text="{Binding Provincia, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" MaxLength="2" />
                            </StackPanel>
                        </Grid>

                        <!-- Riga 5: Date -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Data computo" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                                <DatePicker SelectedDate="{Binding DataComputo}" FontSize="11" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Data prezzi listino" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                                <DatePicker SelectedDate="{Binding DataPrezzi}" FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <!-- Riga 6: Riferimento prezzario + Ribasso -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Riferimento prezzario (es. DEI 2024, Toscana 2024)" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                                <TextBox Text="{Binding RiferimentoPrezzario, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Ribasso d'asta (%)" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                                <TextBox Text="{Binding RibassoPercentuale, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="6,4" />
                            </StackPanel>
                        </Grid>

                        <!-- Riga 7: CIG + CUP -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CIG" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                                <TextBox Text="{Binding Cig, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11" Padding="6,4" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="CUP" FontSize="10" Foreground="{DynamicResource InkMutedBrush}" />
                                <TextBox Text="{Binding Cup, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11" Padding="6,4" />
                            </StackPanel>
                        </Grid>

                        <!-- Footer: Save + status -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding StatusMessage}"
                                       VerticalAlignment="Center"
                                       FontSize="10" FontStyle="Italic"
                                       Foreground="{DynamicResource InkMutedBrush}" />
                            <Button Grid.Column="1"
                                    Content="💾 Salva informazioni progetto"
                                    Command="{Binding SaveCommand}"
                                    Padding="12,4" FontSize="11" FontWeight="SemiBold"
                                    Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ───────────────────────────────────────────────────── -->
                <!-- § 2. LISTINO (Libreria + Ricerca FTS5)                -->
                <!-- ───────────────────────────────────────────────────── -->
                <Border Style="{DynamicResource CardStyle}" Margin="16,0,16,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Header sezione + toolbar -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="LISTINI IN LIBRERIA (PERSISTENTI · CONDIVISI TRA COMPUTI)"
                                       Style="{DynamicResource SectionLabelStyle}"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="BtnImport" Click="OnImportClick"
                                        Content="+ Importa listino…"
                                        Padding="10,4" FontSize="11" FontWeight="SemiBold"
                                        Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                                        BorderThickness="0" Cursor="Hand" />
                                <Button x:Name="BtnBrowse" Click="OnBrowseCatalogClick"
                                        Content="Sfoglia listino…"
                                        Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                        Background="Transparent"
                                        Foreground="{DynamicResource InkDefaultBrush}"
                                        BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                        Cursor="Hand"
                                        ToolTip="Apri finestra con albero gerarchico completo del listino" />
                                <Button x:Name="BtnDelete" Click="OnDeleteClick"
                                        Content="Elimina"
                                        Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                        Background="Transparent"
                                        Foreground="{DynamicResource InkDefaultBrush}"
                                        BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                        Cursor="Hand" />
                            </StackPanel>
                        </Grid>

                        <!-- DataGrid listini -->
                        <DataGrid Grid.Row="1" x:Name="GridPriceLists"
                                  Margin="0,8,0,0"
                                  Height="140"
                                  ItemsSource="{Binding PriceLists}"
                                  SelectedItem="{Binding SelectedPriceList, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  RowHeight="24"
                                  FontSize="11"
                                  Background="White"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource EdgeLightBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nome"     Binding="{Binding Name}"           Width="*" />
                                <DataGridTextColumn Header="Sorgente" Binding="{Binding Source}"         Width="70" />
                                <DataGridTextColumn Header="Regione"  Binding="{Binding Region}"         Width="80" />
                                <DataGridTextColumn Header="Voci"     Binding="{Binding RowCount}"       Width="60" />
                                <DataGridTextColumn Header="Prio"     Binding="{Binding Priority}"       Width="40" />
                                <DataGridCheckBoxColumn Header="Attivo" Binding="{Binding IsActive}"     Width="50" />
                                <DataGridTextColumn Header="Importato" Binding="{Binding ImportedAtShort}" Width="90" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Stato listini -->
                        <TextBlock Grid.Row="2" Margin="0,6,0,8"
                                   Text="{Binding StatusMessage}"
                                   FontSize="10" FontStyle="Italic"
                                   Foreground="{DynamicResource InkMutedBrush}" />

                        <!-- Separatore sottile -->
                        <Border Grid.Row="3" Height="1" Background="{DynamicResource EdgeLightBrush}" Margin="0,0,0,8" />

                        <!-- Ricerca voci EP -->
                        <TextBlock Grid.Row="4"
                                   Text="RICERCA VOCI (CODICE ESATTO → FTS5 → FUZZY)"
                                   Style="{DynamicResource SectionLabelStyle}" />

                        <Grid Grid.Row="5" Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="200" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="SearchBox"
                                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13"
                                         Padding="8,6"
                                         BorderBrush="{DynamicResource EdgeLightBrush}"
                                         BorderThickness="1"
                                         Background="White" />
                                <Border Grid.Column="1"
                                        Background="{DynamicResource PanelSubBrush}"
                                        BorderBrush="{DynamicResource EdgeLightBrush}"
                                        BorderThickness="0,1,1,1"
                                        Padding="8,6"
                                        MinWidth="80">
                                    <TextBlock Text="{Binding LastSearchLevel}"
                                               FontFamily="{DynamicResource FontMono}" FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource BrandAccentDeepBrush}" />
                                </Border>
                            </Grid>

                            <DataGrid Grid.Row="1" x:Name="GridResults"
                                      Margin="0,8,0,0"
                                      ItemsSource="{Binding SearchResults}"
                                      SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeight="24"
                                      FontSize="11"
                                      Background="White"
                                      BorderThickness="1"
                                      BorderBrush="{DynamicResource EdgeLightBrush}"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Codice"      Binding="{Binding Code}"              Width="130" FontFamily="Consolas" />
                                    <DataGridTextColumn Header="Descrizione" Binding="{Binding ShortDescTrimmed}"  Width="*" />
                                    <DataGridTextColumn Header="U.M."        Binding="{Binding Unit}"              Width="50" />
                                    <DataGridTextColumn Header="Prezzo"      Binding="{Binding UnitPriceFormatted}" Width="80" />
                                    <DataGridTextColumn Header="Listino"     Binding="{Binding ListName}"          Width="100" FontSize="10" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="2" Margin="0,6,0,0"
                                       Text="{Binding SearchStatus}"
                                       FontSize="10" FontStyle="Italic"
                                       Foreground="{DynamicResource InkMutedBrush}" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- ───────────────────────────────────────────────────── -->
                <!-- § 3. STRUTTURA COMPUTO (embed ComputoStructureView)   -->
                <!-- ───────────────────────────────────────────────────── -->
                <Border Style="{DynamicResource CardStyle}" Margin="16,0,16,8">
                    <StackPanel>
                        <TextBlock Text="STRUTTURA COMPUTO (CAPITOLI · 3 LIVELLI: SUPER › CAT › SUB)"
                                   Style="{DynamicResource SectionLabelStyle}" />
                        <!-- Host per ComputoStructureView (altezza fissa 380 per UX accettabile in scroll) -->
                        <views:ComputoStructureView Height="380" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- ───────────────────────────────────────────────────── -->
                <!-- § 4. NUOVO PREZZO (placeholder Sprint futuro)         -->
                <!-- ───────────────────────────────────────────────────── -->
                <Border Style="{DynamicResource CardStyle}" Margin="16,0,16,12">
                    <StackPanel>
                        <TextBlock Text="NUOVI PREZZI (ANALISI PREZZI NP)"
                                   Style="{DynamicResource SectionLabelStyle}" />
                        <Border Background="{DynamicResource PanelSubBrush}"
                                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                CornerRadius="3" Padding="16" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Sezione in preparazione"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource InkDefaultBrush}" />
                                <TextBlock Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource InkMutedBrush}"
                                           Text="L'analisi prezzi secondo D.Lgs. 36/2023 All. II.14 (CT = Manodopera + Materiali + Noli + Trasporti × SG × Utile) sarà abilitata in un prossimo rilascio. Tabella NuoviPrezzi già predisposta nel DB schema." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═════════════════════════════════════════════════════════════ -->
        <!-- Footer: placeholder Sprint 6 (regole misurazione)             -->
        <!-- ═════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource PanelSubBrush}"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="0,1,0,0"
                Padding="16,8" Margin="0,0,0,0">
            <TextBlock FontSize="10"
                       Foreground="{DynamicResource InkMutedBrush}"
                       TextWrapping="Wrap"
                       Text="• Regole di misurazione (vuoto per pieno, deduzioni aperture) → Sprint 6  •  Altezza locali QTO_AltezzaLocale per Sorgente B → Sprint 3 (param shared già pronto)" />
        </Border>
    </Grid>
</UserControl>
