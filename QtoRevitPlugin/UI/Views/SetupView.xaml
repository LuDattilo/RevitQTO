<UserControl x:Class="QtoRevitPlugin.UI.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:QtoRevitPlugin.UI.Views">

    <Grid Background="{DynamicResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Titolo view -->
        <Grid Grid.Row="0" Margin="16,14,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Setup" Style="{DynamicResource ViewTitleStyle}" />
            <TextBlock Grid.Column="1" Text="§ Fase 1"
                       VerticalAlignment="Bottom"
                       Foreground="{DynamicResource InkMutedBrush}"
                       FontFamily="{DynamicResource FontMono}" FontSize="10"
                       Margin="8,0,0,12" />
        </Grid>

        <!-- Sub-tab interni: Informazioni / Listino / Struttura Computo / Nuovi Prezzi -->
        <TabControl x:Name="SetupTabs"
                    Grid.Row="1"
                    Margin="12,0,12,0"
                    Background="Transparent"
                    BorderThickness="0">
            <TabItem Header="Informazioni">
                <views:ProjectInfoView />
            </TabItem>
            <TabItem Header="Listino">
                <views:SetupListinoView />
            </TabItem>
            <TabItem Header="Struttura Computo">
                <views:ComputoStructureView />
            </TabItem>
            <TabItem Header="Nuovi Prezzi">
                <views:NuoviPrezziView />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
