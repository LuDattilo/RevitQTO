<UserControl x:Class="QtoRevitPlugin.UI.Views.SetupListinoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QtoRevitPlugin.UI.ViewModels">
    <Grid Background="{DynamicResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar: bottone popout in alto a destra della sub-view -->
        <Grid Grid.Row="0" Margin="16,8,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Gestione listini prezzi + ricerca voci EP"
                       FontSize="11" Foreground="{DynamicResource InkMutedBrush}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" x:Name="BtnPopout" Click="OnPopoutClick"
                    Content="⤢ Apri in finestra"
                    Padding="8,3" FontSize="10"
                    Background="Transparent" Foreground="{DynamicResource InkDimBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    ToolTip="Apre la scheda Listino in una finestra separata per workflow multi-monitor" />
        </Grid>

        <!-- Contenuto: libreria + ricerca -->
        <Border Grid.Row="1" Style="{DynamicResource CardStyle}" Margin="16,4,16,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="LISTINI IN LIBRERIA (PERSISTENTI · CONDIVISI TRA COMPUTI)"
                               Style="{DynamicResource SectionLabelStyle}"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnImport" Click="OnImportClick"
                                Content="+ Importa listino…"
                                Padding="10,4" FontSize="11" FontWeight="SemiBold"
                                Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                                BorderThickness="0" Cursor="Hand" />
                        <Button x:Name="BtnBrowse" Click="OnBrowseCatalogClick"
                                Content="Sfoglia listino…"
                                Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                Background="Transparent"
                                Foreground="{DynamicResource InkDefaultBrush}"
                                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                Cursor="Hand" />
                        <Button x:Name="BtnDelete" Click="OnDeleteClick"
                                Content="Elimina"
                                Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                Background="Transparent"
                                Foreground="{DynamicResource InkDefaultBrush}"
                                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                Cursor="Hand" />
                    </StackPanel>
                </Grid>

                <!--
                    DataGrid Listini (B1): ContextMenu minimale per tasto destro su un listino.
                    Tag="{Binding}" espone SetupViewModel via PlacementTarget.Tag nel menu.
                -->
                <DataGrid x:Name="PriceListsGrid"
                          Grid.Row="1" Margin="0,8,0,0" Height="140"
                          ItemsSource="{Binding PriceLists}"
                          SelectedItem="{Binding SelectedPriceList, Mode=TwoWay}"
                          Tag="{Binding}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="None" RowHeight="24"
                          FontSize="11" Background="White" BorderThickness="1"
                          BorderBrush="{DynamicResource EdgeLightBrush}">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Attivo" Binding="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" Width="55" />
                        <DataGridTextColumn Header="Nome"     Binding="{Binding Name}"           Width="*" />
                        <DataGridTextColumn Header="Sorgente" Binding="{Binding Source}"         Width="70" />
                        <DataGridTextColumn Header="Regione"  Binding="{Binding Region}"         Width="80" />
                        <DataGridTextColumn Header="Voci"     Binding="{Binding RowCount}"       Width="60" />
                        <DataGridTextColumn Header="Prio"     Binding="{Binding Priority}"       Width="40" />
                        <DataGridTextColumn Header="Importato" Binding="{Binding ImportedAtShort}" Width="90" />
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Attiva/Disattiva listino"
                                      Command="{Binding PlacementTarget.Tag.TogglePriceListActiveCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="Sfoglia voci del listino…"
                                      Command="{Binding PlacementTarget.Tag.BrowsePriceListCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <Separator/>
                            <MenuItem Header="🗑 Elimina dalla libreria…"
                                      Command="{Binding PlacementTarget.Tag.DeleteSelectedPriceListCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <TextBlock Grid.Row="2" Margin="0,6,0,8"
                           Text="{Binding StatusMessage}"
                           FontSize="10" FontStyle="Italic"
                           Foreground="{DynamicResource InkMutedBrush}" />

                <Border Grid.Row="3" Height="1" Background="{DynamicResource EdgeLightBrush}" Margin="0,0,0,8" />

                <TextBlock Grid.Row="4"
                           Text="RICERCA VOCI (CODICE ESATTO → FTS5 → FUZZY)"
                           Style="{DynamicResource SectionLabelStyle}" />

                <!--
                    Layout sezione Ricerca (richiesta utente 2026-04-23):
                      Row 0  TextBox ricerca + badge FTS
                      Row 1  DataGrid Risultati (area primaria, flessibile)
                      Row 2  GridSplitter
                      Row 3  Pannello Dettaglio voce selezionata
                      Row 4  Expander "★ I Miei Preferiti" (sotto il dettaglio, come richiesto)
                      Row 5  Status bar
                    I preferiti stanno sotto perché sono destinazione drag&drop dai
                    risultati, e logicamente sono un sottosistema secondario rispetto
                    alla ricerca principale.
                -->
                <Grid Grid.Row="5" Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />    <!-- 0 SearchBox -->
                        <RowDefinition Height="*" MinHeight="120" />  <!-- 1 Risultati -->
                        <RowDefinition Height="3" />       <!-- 2 Splitter -->
                        <RowDefinition Height="Auto" MinHeight="100" /> <!-- 3 Dettaglio -->
                        <RowDefinition Height="Auto" />    <!-- 4 Expander Preferiti -->
                        <RowDefinition Height="Auto" />    <!-- 5 Status -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="SearchBox"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Padding="8,6"
                                 BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                 Background="White" />
                        <Border Grid.Column="1"
                                Background="{DynamicResource PanelSubBrush}"
                                BorderBrush="{DynamicResource EdgeLightBrush}"
                                BorderThickness="0,1,1,1"
                                Padding="8,6" MinWidth="80">
                            <TextBlock Text="{Binding LastSearchLevel}"
                                       FontFamily="{DynamicResource FontMono}" FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrandAccentDeepBrush}" />
                        </Border>
                    </Grid>

                    <Expander x:Name="FavoritesExpander"
                              Grid.Row="4" IsExpanded="True"
                              Margin="0,6,0,0"
                              Background="{DynamicResource PanelSubBrush}"
                              BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                              AllowDrop="True"
                              DragEnter="OnFavoritesDragEnter"
                              DragOver="OnFavoritesDragOver"
                              DragLeave="OnFavoritesDragLeave"
                              Drop="OnFavoritesDrop">
                        <Expander.Header>
                            <Grid HorizontalAlignment="Stretch" Width="Auto">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding FavoritesHeader}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrandAccentDeepBrush}"
                                           VerticalAlignment="Center"/>
                                <!-- Badge conteggio inutilizzati, visibile solo se > 0 -->
                                <TextBlock Grid.Column="2" Margin="10,0,6,0"
                                           VerticalAlignment="Center"
                                           FontSize="10" FontStyle="Italic"
                                           Foreground="{DynamicResource InkMutedBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasUnusedFavorites}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="("/><Run Text="{Binding UnusedFavoritesCount, Mode=OneWay}"/><Run Text=" inutilizzat"/><Run Text="i)"/>
                                </TextBlock>
                                <Button Grid.Column="3"
                                        Content="🗑 Rimuovi inutilizzati"
                                        Command="{Binding RemoveUnusedFavoritesCommand}"
                                        FontSize="10" Padding="8,2" Margin="0,0,4,0"
                                        Cursor="Hand"
                                        Background="Transparent"
                                        Foreground="{DynamicResource InkDefaultBrush}"
                                        BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                        ToolTip="Rimuove dai preferiti le voci NON utilizzate nel computo. Il listino resta intatto.">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasUnusedFavorites}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Expander.Header>
                        <Grid>
                            <!-- Placeholder quando la lista è vuota -->
                            <Border Background="White" BorderThickness="0" Padding="20,16"
                                    Visibility="{Binding FavoritesIsEmpty,
                                                 Converter={x:Static vm:BoolToVisibilityConverter.Instance}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="☆" FontSize="32" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource InkMutedBrush}" />
                                    <TextBlock Text="Nessun preferito ancora"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource InkDefaultBrush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,2" />
                                    <TextBlock Text="Seleziona una voce nei risultati e clicca la stellina ★ per aggiungerla qui."
                                               FontSize="10" FontStyle="Italic"
                                               Foreground="{DynamicResource InkMutedBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"
                                               MaxWidth="360" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- DataGrid preferiti (nascosto quando vuoto) -->
                            <DataGrid x:Name="FavoritesGrid"
                                      ItemsSource="{Binding Favorites}"
                                      SelectedItem="{Binding SelectedFavorite, Mode=TwoWay}"
                                      Tag="{Binding}"
                                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" FontSize="11" FontWeight="Normal"
                                      Foreground="{DynamicResource InkDefaultBrush}"
                                      MaxHeight="160" GridLinesVisibility="None"
                                      IsReadOnly="True"
                                      Visibility="{Binding FavoritesIsEmpty,
                                                   Converter={x:Static vm:InverseBoolToVisibilityConverter.Instance}}">
                                <DataGrid.Columns>
                                    <!-- Colonna "Usato": mostra ✓ verde se la voce è assegnata nel computo, — grigio altrimenti -->
                                    <DataGridTemplateColumn Header="Usato" Width="58" SortMemberPath="IsUsedInComputo">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding UsedBadge}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource InkMutedBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUsedInComputo}" Value="True">
                                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Codice"      Binding="{Binding Code}"               Width="130" FontFamily="Consolas"/>
                                    <DataGridTextColumn Header="Descrizione" Binding="{Binding Description}"        Width="*"/>
                                    <DataGridTextColumn Header="U.M."        Binding="{Binding Unit}"               Width="50"/>
                                    <DataGridTextColumn Header="Prezzo"      Binding="{Binding UnitPriceFormatted}"  Width="80"/>
                                    <DataGridTextColumn Header="Listino"     Binding="{Binding ListName}"           Width="110" FontSize="10"/>
                                    <DataGridTextColumn Header="Aggiunto"    Binding="{Binding AddedAtShort}"       Width="115" FontSize="10"/>
                                </DataGrid.Columns>
                                <!--
                                    Pattern ContextMenu sulla DataGrid (non sul RowStyle) per evitare la dipendenza
                                    ciclica XAML che fa crashare InitializeComponent. La ContextMenu è attached alla
                                    DataGrid stessa; il Command legge dal Tag della DataGrid che punta al VM.
                                -->
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Usa nella ricerca"
                                                  Command="{Binding PlacementTarget.Tag.UseFavoriteInSearchCommand,
                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Rimuovi dai preferiti"
                                                  Command="{Binding PlacementTarget.Tag.RemoveFavoriteCommand,
                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="🗑 Rimuovi tutti gli inutilizzati"
                                                  Command="{Binding PlacementTarget.Tag.RemoveUnusedFavoritesCommand,
                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  ToolTip="Rimuove dai preferiti solo le voci non assegnate nel computo. Il listino resta intatto."/>
                                        <MenuItem Header="↻ Aggiorna stato 'Usato'"
                                                  Command="{Binding PlacementTarget.Tag.RefreshFavoritesUsageFromUiCommand,
                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  ToolTip="Ricalcola quali preferiti sono attualmente usati nel computo"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>
                        </Grid>
                    </Expander>

                    <!--
                        Risultati ricerca: doppio click su riga → toggle preferito (UX test feedback).
                        Prima colonna: bottone cliccabile che mostra "★" se preferita (dorato) o "+"
                        se non preferita (grigio con hover dorato). La cella stessa è interattiva,
                        così l'utente può aggiungere/rimuovere senza aprire dettaglio o ribbon.
                        Tag="{Binding}" sulla DataGrid espone il SetupViewModel via PlacementTarget.
                    -->
                    <DataGrid x:Name="SearchResultsGrid"
                              Grid.Row="1" Margin="0,8,0,0"
                              ItemsSource="{Binding SearchResults}"
                              SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
                              Tag="{Binding}"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="24"
                              FontSize="11" Background="White" BorderThickness="1"
                              BorderBrush="{DynamicResource EdgeLightBrush}"
                              MouseDoubleClick="OnSearchResultDoubleClick"
                              PreviewMouseLeftButtonDown="OnSearchResultMouseDown"
                              MouseMove="OnSearchResultMouseMove">
                        <DataGrid.Columns>
                            <!-- Bottone per toggle preferito: "★" se preferita, "+" se non preferita -->
                            <DataGridTemplateColumn Header="Preferiti" Width="62" IsReadOnly="True" SortMemberPath="IsFavoriteInLibrary">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Width="24" Height="20" Padding="0" Cursor="Hand"
                                                BorderThickness="0" Background="Transparent"
                                                Command="{Binding DataContext.ToggleFavoriteForRowCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                FontSize="14" FontWeight="Bold">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Content" Value="+"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource InkMutedBrush}"/>
                                                    <Setter Property="ToolTip" Value="Aggiungi ai preferiti (doppio click sulla riga equivalente)"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="Goldenrod"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsFavoriteInLibrary}" Value="True">
                                                            <Setter Property="Content" Value="★"/>
                                                            <Setter Property="Foreground" Value="Goldenrod"/>
                                                            <Setter Property="ToolTip" Value="Rimuovi dai preferiti"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Codice"      Binding="{Binding Code}"              Width="130" FontFamily="Consolas" />
                            <DataGridTextColumn Header="Descrizione" Binding="{Binding ShortDescTrimmed}"  Width="*" />
                            <DataGridTextColumn Header="U.M."        Binding="{Binding Unit}"              Width="50" />
                            <DataGridTextColumn Header="Prezzo"      Binding="{Binding UnitPriceFormatted}" Width="80" />
                            <DataGridTextColumn Header="Listino"     Binding="{Binding ListName}"          Width="100" FontSize="10" />
                        </DataGrid.Columns>
                        <!--
                            ContextMenu minimale sui risultati ricerca: toggle preferito
                            (stessa azione del bottone cella e del doppio click) + copia
                            codice negli appunti (use case frequente per incollare in altro tool).
                        -->
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{Binding PlacementTarget.SelectedItem.FavoriteMenuLabel,
                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Command="{Binding PlacementTarget.Tag.ToggleFavoriteForRowCommand,
                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem,
                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <Separator/>
                                <MenuItem Header="Copia codice"
                                          Command="{Binding PlacementTarget.Tag.CopyCodeToClipboardCommand,
                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem,
                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>

                    <GridSplitter Grid.Row="2" Height="3" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                  Background="{DynamicResource EdgeLightBrush}" ShowsPreview="False" Cursor="SizeNS" />

                    <Border Grid.Row="3"
                            Background="{DynamicResource PanelSubBrush}"
                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                            Margin="0,4,0,0"
                            DataContext="{Binding SelectedSearchResult}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,8">
                            <StackPanel>
                                <!--
                                    Header del dettaglio: Codice · ListName · Prezzo.
                                    Il bottone preferito è stato RIMOSSO dal dettaglio (feedback utente:
                                    "non chiaro, non immediato"). I modi per aggiungere/rimuovere una
                                    voce dai preferiti sono:
                                      1) Bottone "+" / "★" nella prima cella della riga risultati
                                      2) Doppio click sulla riga risultati
                                      3) Tasto destro → "Aggiungi/Rimuovi dai preferiti" (contextmenu)
                                      4) Drag & drop della riga nell'expander Preferiti
                                -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Code}"
                                               FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource BrandAccentDeepBrush}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,10,0"
                                               Text="{Binding ListName}" FontSize="10"
                                               Foreground="{DynamicResource InkMutedBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding UnitPriceFormatted}"
                                               FontFamily="{DynamicResource FontMono}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrandAccentDeepBrush}" />
                                </Grid>
                                <TextBlock Text="{Binding HierarchyPath}" Margin="0,4,0,0"
                                           FontSize="10" Foreground="{DynamicResource InkMutedBrush}"
                                           TextWrapping="Wrap" />
                                <Border Height="1" Margin="0,6,0,6"
                                        Background="{DynamicResource EdgeLightBrush}" />
                                <TextBlock Text="{Binding Description}" FontSize="11" LineHeight="16"
                                           Foreground="{DynamicResource InkDefaultBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <TextBlock Grid.Row="5" Margin="0,6,0,0"
                               Text="{Binding SearchStatus}"
                               FontSize="10" FontStyle="Italic"
                               Foreground="{DynamicResource InkMutedBrush}" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource PanelSubBrush}"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock FontSize="10"
                       Foreground="{DynamicResource InkMutedBrush}"
                       TextWrapping="Wrap"
                       Text="Questa scheda è il punto di ingresso per importare prezzari DEI/PriMus/XML e ricercare voci EP." />
        </Border>
    </Grid>
</UserControl>
