<UserControl x:Class="QtoRevitPlugin.UI.Views.SetupListinoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QtoRevitPlugin.UI.ViewModels">
    <Grid Background="{DynamicResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar: popout -->
        <Grid Grid.Row="0" Margin="16,8,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Gestione listini prezzi · ricerca ibrida · preferiti progetto/personali"
                       FontSize="11" Foreground="{DynamicResource InkMutedBrush}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" x:Name="BtnPopout" Click="OnPopoutClick"
                    Content="⤢ Apri in finestra"
                    Padding="8,3" FontSize="10"
                    Background="Transparent" Foreground="{DynamicResource InkDimBrush}"
                    BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    ToolTip="Apre la scheda Listino in una finestra separata per workflow multi-monitor" />
        </Grid>

        <!-- Contenuto principale -->
        <Border Grid.Row="1" Style="{DynamicResource CardStyle}" Margin="16,4,16,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />   <!-- Toolbar listini -->
                    <RowDefinition Height="Auto" />   <!-- DataGrid listini -->
                    <RowDefinition Height="Auto" />   <!-- Status message -->
                    <RowDefinition Height="Auto" />   <!-- Separator -->
                    <RowDefinition Height="Auto" />   <!-- Section label -->
                    <RowDefinition Height="*" />      <!-- Area ricerca/preferiti (TabControl) -->
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="LISTINI IN LIBRERIA (PERSISTENTI · CONDIVISI TRA COMPUTI)"
                               Style="{DynamicResource SectionLabelStyle}"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnImport" Click="OnImportClick"
                                Content="+ Importa listino…"
                                Padding="10,4" FontSize="11" FontWeight="SemiBold"
                                Background="{DynamicResource BrandAccentBrush}" Foreground="White"
                                BorderThickness="0" Cursor="Hand" />
                        <Button x:Name="BtnBrowse" Click="OnBrowseCatalogClick"
                                Content="Sfoglia listino…"
                                Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                Background="Transparent"
                                Foreground="{DynamicResource InkDefaultBrush}"
                                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                Cursor="Hand" />
                        <Button x:Name="BtnDelete" Click="OnDeleteClick"
                                Content="Elimina"
                                Margin="6,0,0,0" Padding="10,4" FontSize="11"
                                Background="Transparent"
                                Foreground="{DynamicResource InkDefaultBrush}"
                                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                Cursor="Hand" />
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="PriceListsGrid"
                          Grid.Row="1" Margin="0,8,0,0" Height="140"
                          ItemsSource="{Binding PriceLists}"
                          SelectedItem="{Binding SelectedPriceList, Mode=TwoWay}"
                          Tag="{Binding}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="None" RowHeight="24"
                          FontSize="11" Background="White" BorderThickness="1"
                          BorderBrush="{DynamicResource EdgeLightBrush}">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Attivo"   Binding="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" Width="55" />
                        <DataGridTextColumn     Header="Nome"     Binding="{Binding Name}"           Width="*" />
                        <DataGridTextColumn     Header="Sorgente" Binding="{Binding Source}"         Width="70" />
                        <DataGridTextColumn     Header="Regione"  Binding="{Binding Region}"         Width="80" />
                        <DataGridTextColumn     Header="Voci"     Binding="{Binding RowCount}"       Width="60" />
                        <DataGridTextColumn     Header="Prio"     Binding="{Binding Priority}"       Width="40" />
                        <DataGridTextColumn     Header="Importato" Binding="{Binding ImportedAtShort}" Width="90" />
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Attiva/Disattiva listino"
                                      Command="{Binding PlacementTarget.Tag.TogglePriceListActiveCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="Sfoglia voci del listino…"
                                      Command="{Binding PlacementTarget.Tag.BrowsePriceListCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <Separator/>
                            <MenuItem Header="🗑 Elimina dalla libreria…"
                                      Command="{Binding PlacementTarget.Tag.DeleteSelectedPriceListCommand,
                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <TextBlock Grid.Row="2" Margin="0,6,0,8"
                           Text="{Binding StatusMessage}"
                           FontSize="10" FontStyle="Italic"
                           Foreground="{DynamicResource InkMutedBrush}" />

                <Border Grid.Row="3" Height="1" Background="{DynamicResource EdgeLightBrush}" Margin="0,0,0,8" />

                <TextBlock Grid.Row="4"
                           Text="RICERCA IBRIDA · PREFERITI PROGETTO · PREFERITI PERSONALI"
                           Style="{DynamicResource SectionLabelStyle}" />

                <!-- SearchBar + TabControl a 3 schede -->
                <Grid Grid.Row="5" Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- SearchBox + scope combo + badge -->
                        <RowDefinition Height="*" MinHeight="160" />  <!-- TabControl -->
                        <RowDefinition Height="3" />     <!-- Splitter -->
                        <RowDefinition Height="Auto" MinHeight="90" MaxHeight="180" /> <!-- Dettaglio -->
                        <RowDefinition Height="Auto" /> <!-- Status -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="SearchBox"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Padding="8,6"
                                 BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                 Background="White" />
                        <ComboBox Grid.Column="1"
                                  Margin="8,0,8,0"
                                  ItemsSource="{Binding AvailableScopes}"
                                  SelectedValuePath="Scope"
                                  DisplayMemberPath="Label"
                                  SelectedValue="{Binding SelectedScope, Mode=TwoWay}"
                                  FontSize="11" Padding="6,3" />
                        <Border Grid.Column="2"
                                Background="{DynamicResource PanelSubBrush}"
                                BorderBrush="{DynamicResource EdgeLightBrush}"
                                BorderThickness="0,1,1,1"
                                Padding="8,6" MinWidth="80">
                            <TextBlock Text="{Binding LastSearchLevel}"
                                       FontFamily="{DynamicResource FontMono}" FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource BrandAccentDeepBrush}" />
                        </Border>
                    </Grid>

                    <!--
                        TabControl a 3 schede (Fase 4):
                          Ricerca ibrida   — risultati del listino attivo + ★ cell button + drag
                          Preferiti progetto — lista preferiti legati al .cme corrente
                                             (drop-target per drag&drop)
                          Preferiti personali — lista preferiti globali utente
                                              (drop-target per drag&drop)
                    -->
                    <TabControl Grid.Row="1" Margin="0,8,0,0" Background="Transparent">

                        <!-- TAB 1: Ricerca ibrida -->
                        <TabItem Header="Ricerca ibrida">
                            <DataGrid x:Name="SearchResultsGrid"
                                      ItemsSource="{Binding SearchResults}"
                                      SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
                                      Tag="{Binding}"
                                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="24"
                                      FontSize="11" Background="White" BorderThickness="1"
                                      BorderBrush="{DynamicResource EdgeLightBrush}"
                                      MouseDoubleClick="OnSearchResultDoubleClick"
                                      PreviewMouseLeftButtonDown="OnSearchResultMouseDown"
                                      MouseMove="OnSearchResultMouseMove">
                                <DataGrid.Columns>
                                    <!-- Cell-★ button: toggle preferito (default = Project scope sul primo add) -->
                                    <DataGridTemplateColumn Header="★" Width="48" IsReadOnly="True"
                                                            SortMemberPath="IsFavoriteInLibrary">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Width="24" Height="20" Padding="0" Cursor="Hand"
                                                        BorderThickness="0" Background="Transparent"
                                                        Command="{Binding DataContext.ToggleFavoriteForRowCommand,
                                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Content="{Binding FavoriteBadge}"
                                                        FontSize="14" FontWeight="Bold">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Foreground" Value="{DynamicResource InkMutedBrush}"/>
                                                            <Setter Property="ToolTip" Value="Aggiungi ai preferiti (default: progetto · tasto destro per scegliere scope)"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource BrandAccentDeepBrush}"/>
                                                                </Trigger>
                                                                <DataTrigger Binding="{Binding FavoriteScopeInLibrary}" Value="Project">
                                                                    <Setter Property="Foreground" Value="{DynamicResource BrandAccentDeepBrush}"/>
                                                                    <Setter Property="ToolTip" Value="★ Nei preferiti progetto — click per rimuovere"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding FavoriteScopeInLibrary}" Value="Personal">
                                                                    <Setter Property="Foreground" Value="Goldenrod"/>
                                                                    <Setter Property="ToolTip" Value="★ Nei preferiti personali — click per rimuovere"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Codice"      Binding="{Binding Code}"              Width="130" FontFamily="Consolas" />
                                    <DataGridTextColumn Header="Descrizione" Binding="{Binding ShortDescTrimmed}"  Width="*" />
                                    <DataGridTextColumn Header="U.M."        Binding="{Binding Unit}"              Width="50" />
                                    <DataGridTextColumn Header="Prezzo"      Binding="{Binding UnitPriceFormatted}" Width="80" />
                                    <DataGridTextColumn Header="Listino"     Binding="{Binding ListName}"          Width="100" FontSize="10" />
                                </DataGrid.Columns>
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{Binding PlacementTarget.SelectedItem.FavoriteMenuLabel,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Command="{Binding PlacementTarget.Tag.ToggleFavoriteForRowCommand,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="★ Aggiungi a preferiti PROGETTO"
                                                  Command="{Binding PlacementTarget.Tag.AddFavoriteToProjectCommand,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="★ Aggiungi a preferiti PERSONALI"
                                                  Command="{Binding PlacementTarget.Tag.AddFavoriteToPersonalCommand,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="Copia codice"
                                                  Command="{Binding PlacementTarget.Tag.CopyCodeToClipboardCommand,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>
                        </TabItem>

                        <!-- TAB 2: Preferiti progetto · drop target -->
                        <TabItem x:Name="TabProjectFavorites"
                                 Header="{Binding ProjectFavoritesHeader}"
                                 AllowDrop="True"
                                 DragEnter="OnFavoritesProjectDragEnter"
                                 DragOver="OnFavoritesProjectDragOver"
                                 DragLeave="OnFavoritesDragLeave"
                                 Drop="OnFavoritesProjectDrop">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="2,4,2,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Preferiti legati al file .cme aperto · trascina una voce qui per aggiungerla"
                                               FontSize="10" FontStyle="Italic"
                                               Foreground="{DynamicResource InkMutedBrush}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Content="🗑 Rimuovi inutilizzati"
                                            Command="{Binding RemoveUnusedProjectFavoritesCommand}"
                                            FontSize="10" Padding="8,2"
                                            Cursor="Hand"
                                            Background="Transparent"
                                            Foreground="{DynamicResource InkDefaultBrush}"
                                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                            ToolTip="Rimuove dai preferiti progetto le voci NON utilizzate nel computo. Il listino resta intatto.">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasProjectUnused}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>

                                <!-- Placeholder empty-state -->
                                <Border Grid.Row="1" Background="White" BorderThickness="0" Padding="20,16"
                                        Visibility="{Binding ProjectFavoritesIsEmpty,
                                                     Converter={x:Static vm:BoolToVisibilityConverter.Instance}}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="☆" FontSize="32" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource InkMutedBrush}" />
                                        <TextBlock Text="Nessun preferito progetto"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource InkDefaultBrush}"
                                                   HorizontalAlignment="Center" Margin="0,4,0,2" />
                                        <TextBlock Text="Trascina una voce dalla tab «Ricerca ibrida» qui, oppure usa il menu contestuale (tasto destro)."
                                                   FontSize="10" FontStyle="Italic"
                                                   Foreground="{DynamicResource InkMutedBrush}"
                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                   MaxWidth="360" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <DataGrid Grid.Row="1"
                                          x:Name="ProjectFavoritesGrid"
                                          ItemsSource="{Binding ProjectFavorites}"
                                          SelectedItem="{Binding SelectedProjectFavorite, Mode=TwoWay}"
                                          Tag="{Binding}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                          HeadersVisibility="Column" GridLinesVisibility="None" RowHeight="24"
                                          FontSize="11" Background="White" BorderThickness="1"
                                          BorderBrush="{DynamicResource EdgeLightBrush}" IsReadOnly="True"
                                          Visibility="{Binding ProjectFavoritesIsEmpty,
                                                       Converter={x:Static vm:InverseBoolToVisibilityConverter.Instance}}">
                                    <DataGrid.Columns>
                                        <!-- Colonna "Usato": ✓ verde se assegnato nel computo -->
                                        <DataGridTemplateColumn Header="Usato" Width="58" SortMemberPath="IsUsedInComputo">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding UsedBadge}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="11" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource InkMutedBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUsedInComputo}" Value="True">
                                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Codice"      Binding="{Binding Code}"               Width="130" FontFamily="Consolas"/>
                                        <DataGridTextColumn Header="Descrizione" Binding="{Binding Description}"        Width="*"/>
                                        <DataGridTextColumn Header="U.M."        Binding="{Binding Unit}"               Width="50"/>
                                        <DataGridTextColumn Header="Prezzo"      Binding="{Binding UnitPriceFormatted}" Width="80"/>
                                        <DataGridTextColumn Header="Listino"     Binding="{Binding ListName}"           Width="110" FontSize="10"/>
                                        <DataGridTextColumn Header="Aggiunto"    Binding="{Binding AddedAtShort}"       Width="115" FontSize="10"/>
                                    </DataGrid.Columns>
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Usa nella ricerca"
                                                      Command="{Binding PlacementTarget.Tag.UseFavoriteInSearchCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Copia codice"
                                                      Command="{Binding PlacementTarget.Tag.CopyCodeToClipboardCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator/>
                                            <MenuItem Header="→ Sposta in PERSONALI"
                                                      Command="{Binding PlacementTarget.Tag.MoveFavoriteToPersonalCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator/>
                                            <MenuItem Header="🗑 Rimuovi dai preferiti"
                                                      Command="{Binding PlacementTarget.Tag.RemoveFavoriteCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="↻ Aggiorna stato 'Usato'"
                                                      Command="{Binding PlacementTarget.Tag.RefreshFavoritesUsageFromUiCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      ToolTip="Ricalcola quali preferiti sono attualmente usati nel computo"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <!-- TAB 3: Preferiti personali · drop target -->
                        <TabItem x:Name="TabPersonalFavorites"
                                 Header="{Binding PersonalFavoritesHeader}"
                                 AllowDrop="True"
                                 DragEnter="OnFavoritesPersonalDragEnter"
                                 DragOver="OnFavoritesPersonalDragOver"
                                 DragLeave="OnFavoritesDragLeave"
                                 Drop="OnFavoritesPersonalDrop">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="2,4,2,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Preferiti globali utente (AppData) · condivisi tra tutti i computi"
                                               FontSize="10" FontStyle="Italic"
                                               Foreground="{DynamicResource InkMutedBrush}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Content="🗑 Rimuovi inutilizzati"
                                            Command="{Binding RemoveUnusedPersonalFavoritesCommand}"
                                            FontSize="10" Padding="8,2"
                                            Cursor="Hand"
                                            Background="Transparent"
                                            Foreground="{DynamicResource InkDefaultBrush}"
                                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                                            ToolTip="Rimuove dai preferiti personali le voci NON utilizzate nel computo corrente.">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPersonalUnused}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>

                                <Border Grid.Row="1" Background="White" BorderThickness="0" Padding="20,16"
                                        Visibility="{Binding PersonalFavoritesIsEmpty,
                                                     Converter={x:Static vm:BoolToVisibilityConverter.Instance}}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="☆" FontSize="32" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource InkMutedBrush}" />
                                        <TextBlock Text="Nessun preferito personale"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource InkDefaultBrush}"
                                                   HorizontalAlignment="Center" Margin="0,4,0,2" />
                                        <TextBlock Text="Trascina una voce dalla tab «Ricerca ibrida» qui, oppure usa il menu contestuale (tasto destro)."
                                                   FontSize="10" FontStyle="Italic"
                                                   Foreground="{DynamicResource InkMutedBrush}"
                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                   MaxWidth="360" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <DataGrid Grid.Row="1"
                                          x:Name="PersonalFavoritesGrid"
                                          ItemsSource="{Binding PersonalFavorites}"
                                          SelectedItem="{Binding SelectedPersonalFavorite, Mode=TwoWay}"
                                          Tag="{Binding}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                          HeadersVisibility="Column" GridLinesVisibility="None" RowHeight="24"
                                          FontSize="11" Background="White" BorderThickness="1"
                                          BorderBrush="{DynamicResource EdgeLightBrush}" IsReadOnly="True"
                                          Visibility="{Binding PersonalFavoritesIsEmpty,
                                                       Converter={x:Static vm:InverseBoolToVisibilityConverter.Instance}}">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Usato" Width="58" SortMemberPath="IsUsedInComputo">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding UsedBadge}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="11" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource InkMutedBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUsedInComputo}" Value="True">
                                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Codice"      Binding="{Binding Code}"               Width="130" FontFamily="Consolas"/>
                                        <DataGridTextColumn Header="Descrizione" Binding="{Binding Description}"        Width="*"/>
                                        <DataGridTextColumn Header="U.M."        Binding="{Binding Unit}"               Width="50"/>
                                        <DataGridTextColumn Header="Prezzo"      Binding="{Binding UnitPriceFormatted}" Width="80"/>
                                        <DataGridTextColumn Header="Listino"     Binding="{Binding ListName}"           Width="110" FontSize="10"/>
                                        <DataGridTextColumn Header="Aggiunto"    Binding="{Binding AddedAtShort}"       Width="115" FontSize="10"/>
                                    </DataGrid.Columns>
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Usa nella ricerca"
                                                      Command="{Binding PlacementTarget.Tag.UseFavoriteInSearchCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Copia codice"
                                                      Command="{Binding PlacementTarget.Tag.CopyCodeToClipboardCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator/>
                                            <MenuItem Header="→ Sposta in PROGETTO"
                                                      Command="{Binding PlacementTarget.Tag.MoveFavoriteToProjectCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator/>
                                            <MenuItem Header="🗑 Rimuovi dai preferiti"
                                                      Command="{Binding PlacementTarget.Tag.RemoveFavoriteCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="↻ Aggiorna stato 'Usato'"
                                                      Command="{Binding PlacementTarget.Tag.RefreshFavoritesUsageFromUiCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <!-- Splitter tra TabControl e pannello dettaglio -->
                    <GridSplitter Grid.Row="2" Height="3"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                  Background="{DynamicResource EdgeLightBrush}"
                                  ShowsPreview="False" Cursor="SizeNS" />

                    <!-- Pannello Dettaglio -->
                    <Border Grid.Row="3"
                            Background="{DynamicResource PanelSubBrush}"
                            BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="1"
                            Margin="0,4,0,0"
                            DataContext="{Binding SelectedDetailItem}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,8">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Code}"
                                               FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource BrandAccentDeepBrush}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,10,0"
                                               Text="{Binding SourceLabel}" FontSize="10"
                                               Foreground="{DynamicResource InkMutedBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding UnitPriceFormatted}"
                                               FontFamily="{DynamicResource FontMono}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrandAccentDeepBrush}" />
                                </Grid>
                                <TextBlock Text="{Binding HierarchyPath}" Margin="0,4,0,0"
                                           FontSize="10" Foreground="{DynamicResource InkMutedBrush}"
                                           TextWrapping="Wrap" />
                                <Border Height="1" Margin="0,6,0,6"
                                        Background="{DynamicResource EdgeLightBrush}" />
                                <TextBlock Text="{Binding Description}" FontSize="11" LineHeight="16"
                                           Foreground="{DynamicResource InkDefaultBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <TextBlock Grid.Row="4" Margin="0,6,0,0"
                               Text="{Binding SearchStatus}"
                               FontSize="10" FontStyle="Italic"
                               Foreground="{DynamicResource InkMutedBrush}" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource PanelSubBrush}"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock FontSize="10"
                       Foreground="{DynamicResource InkMutedBrush}"
                       TextWrapping="Wrap"
                       Text="Listino persistente tra computi · preferiti PROGETTO nel .cme · preferiti PERSONALI in AppData." />
        </Border>
    </Grid>
</UserControl>
