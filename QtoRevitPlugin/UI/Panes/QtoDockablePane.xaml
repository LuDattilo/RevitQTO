<UserControl x:Class="QtoRevitPlugin.UI.Panes.QtoDockablePane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="640" MinHeight="780">

    <!-- Il tema QtoTheme.xaml è caricato in Application.Current.Resources da QtoApplication.OnStartup -->

    <Grid Background="{DynamicResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header brand scuro (stile engineering) -->
        <Border Grid.Row="0" Background="{DynamicResource ChromeBgBrush}" Padding="14,10">
            <StackPanel>
                <!-- Riga superiore: logo + titolo + version + LIVE badge -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Logo Q arancione -->
                    <Border Grid.Column="0" Background="{DynamicResource BrandAccentBrush}"
                            Width="26" Height="26" CornerRadius="2"
                            VerticalAlignment="Center">
                        <TextBlock Text="Q" Foreground="White"
                                   FontFamily="{DynamicResource FontDisplay}"
                                   FontSize="15" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <!-- Titolo uppercase -->
                    <TextBlock Grid.Column="1" Text="CME"
                               Foreground="{DynamicResource ChromeTextBrush}"
                               FontFamily="{DynamicResource FontDisplay}"
                               FontSize="13" FontWeight="Bold"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center" />

                    <!-- Menu Sessione (file-like: Nuovo/Apri/Salva/SalvaConNome/Rinomina/Chiudi/Elimina) -->
                    <Button Grid.Column="2"
                            x:Name="SessionMenuButton"
                            Click="OnSessionMenuClick"
                            Margin="14,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Padding="8,4"
                            Background="Transparent"
                            Foreground="{DynamicResource ChromeTextBrush}"
                            BorderBrush="{DynamicResource ChromeEdgeBrush}"
                            BorderThickness="1"
                            FontFamily="{DynamicResource FontBody}"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Sessione" />
                                <TextBlock Text=" ▾" Opacity="0.7" />
                            </StackPanel>
                        </Button.Content>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="SessionContextMenu">
                                <MenuItem x:Name="MiNew" Header="Nuovo computo…" Click="OnNewSession" />
                                <MenuItem x:Name="MiOpen" Header="Apri computo…" Click="OnOpenSession" />
                                <Separator />
                                <MenuItem x:Name="MiSave" Header="Salva" Click="OnSave" />
                                <MenuItem x:Name="MiSaveAs" Header="Salva con nome…" Click="OnSaveAs" />
                                <Separator />
                                <MenuItem x:Name="MiRename" Header="Rinomina…" Click="OnRename" />
                                <MenuItem x:Name="MiClose" Header="Chiudi computo" Click="OnClose" />
                                <Separator />
                                <MenuItem x:Name="MiDelete" Header="Elimina…" Click="OnDelete" />
                                <Separator />
                                <MenuItem x:Name="MiSettings" Header="Impostazioni…" Click="OnSettings" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- Version -->
                    <TextBlock Grid.Column="3" Text="v1.0"
                               Foreground="{DynamicResource ChromeTextDimBrush}"
                               FontFamily="{DynamicResource FontMono}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />

                    <!-- Badge LIVE arancione -->
                    <Border Grid.Column="4"
                            Background="{DynamicResource BrandAccentBrush}"
                            CornerRadius="2" Padding="5,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="LIVE" Foreground="White"
                                   FontFamily="{DynamicResource FontMono}"
                                   FontSize="9" FontWeight="Bold"
                                   LineHeight="10" />
                    </Border>
                </Grid>

                <!-- Riga inferiore: sessione corrente -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding SessionTitle}"
                                   Foreground="{DynamicResource ChromeTextBrush}"
                                   FontFamily="{DynamicResource FontBody}"
                                   FontSize="11" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding ProjectSubtitle}"
                                   Foreground="{DynamicResource ChromeTextDimBrush}"
                                   FontFamily="{DynamicResource FontMono}"
                                   FontSize="10"
                                   Margin="0,1,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ProgressText}"
                                   Foreground="{DynamicResource ChromeTextDimBrush}"
                                   FontFamily="{DynamicResource FontMono}" FontSize="10"
                                   HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding AmountText}"
                                   Foreground="{DynamicResource BrandAccentBrush}"
                                   FontFamily="{DynamicResource FontMono}"
                                   FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- View switcher su chrome scuro -->
        <Border Grid.Row="1" Background="{DynamicResource ChromeBgBrush}"
                BorderBrush="{DynamicResource ChromeEdgeBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,8,14,10">
            <StackPanel>
                <TextBlock Text="VISTA CORRENTE"
                           Foreground="{DynamicResource BrandAccentBrush}"
                           FontFamily="{DynamicResource FontMono}"
                           FontSize="9" FontWeight="Bold"
                           Margin="0,0,0,6" />
                <WrapPanel x:Name="SwitcherHost" Orientation="Horizontal" />
            </StackPanel>
        </Border>

        <!-- Content area: view attiva -->
        <ContentControl Grid.Row="2" x:Name="ViewHost" />

        <!-- Status bar -->
        <Border Grid.Row="3" Background="{DynamicResource PanelSubBrush}"
                BorderBrush="{DynamicResource EdgeLightBrush}" BorderThickness="0,1,0,0"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           FontSize="11"
                           Foreground="{DynamicResource InkDimBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding ActiveView.Reference}"
                           FontFamily="{DynamicResource FontMono}"
                           FontSize="10"
                           Foreground="{DynamicResource InkMutedBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
