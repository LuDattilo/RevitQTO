<!--
    QTO design tokens — stile semplificato dal mockup HTML, senza Google Fonts.
    Segoe UI nativo Windows / Revit. Palette stati: §I5 QTO-Implementazioni-v3.md.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colori brand -->
    <Color x:Key="BrandPrimary">#1F4E79</Color>
    <Color x:Key="BrandAccent">#EA580C</Color>
    <Color x:Key="BrandAccentDeep">#9A3412</Color>
    <Color x:Key="BrandAccentSoft">#FED7AA</Color>
    <Color x:Key="BrandCool">#075985</Color>

    <!-- Stati QTO (allineati a StateColors.cs Core) -->
    <Color x:Key="StateComputato">#16A34A</Color>
    <Color x:Key="StateMancante">#DC2626</Color>
    <Color x:Key="StateParziale">#CA8A04</Color>
    <Color x:Key="StateMultiEP">#2563EB</Color>
    <Color x:Key="StateAdded">#EA580C</Color>
    <Color x:Key="StateEscluso">#78716C</Color>

    <!-- Neutrali / chrome -->
    <Color x:Key="PanelBg">#FAFAF9</Color>
    <Color x:Key="PanelSub">#F5F5F4</Color>
    <Color x:Key="EdgeLight">#E7E5E4</Color>
    <Color x:Key="EdgeMedium">#D6D3D1</Color>
    <Color x:Key="EdgeStrong">#A8A29E</Color>
    <Color x:Key="InkDefault">#0C0A09</Color>
    <Color x:Key="InkDim">#57534E</Color>
    <Color x:Key="InkMuted">#78716C</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="{StaticResource BrandPrimary}" />
    <SolidColorBrush x:Key="BrandAccentBrush" Color="{StaticResource BrandAccent}" />
    <SolidColorBrush x:Key="BrandAccentDeepBrush" Color="{StaticResource BrandAccentDeep}" />
    <SolidColorBrush x:Key="BrandAccentSoftBrush" Color="{StaticResource BrandAccentSoft}" />
    <SolidColorBrush x:Key="BrandCoolBrush" Color="{StaticResource BrandCool}" />

    <SolidColorBrush x:Key="StateComputatoBrush" Color="{StaticResource StateComputato}" />
    <SolidColorBrush x:Key="StateMancanteBrush" Color="{StaticResource StateMancante}" />
    <SolidColorBrush x:Key="StateParzialeBrush" Color="{StaticResource StateParziale}" />
    <SolidColorBrush x:Key="StateMultiEPBrush" Color="{StaticResource StateMultiEP}" />
    <SolidColorBrush x:Key="StateAddedBrush" Color="{StaticResource StateAdded}" />
    <SolidColorBrush x:Key="StateEsclusoBrush" Color="{StaticResource StateEscluso}" />

    <SolidColorBrush x:Key="PanelBgBrush" Color="{StaticResource PanelBg}" />
    <SolidColorBrush x:Key="PanelSubBrush" Color="{StaticResource PanelSub}" />
    <SolidColorBrush x:Key="EdgeLightBrush" Color="{StaticResource EdgeLight}" />
    <SolidColorBrush x:Key="EdgeMediumBrush" Color="{StaticResource EdgeMedium}" />
    <SolidColorBrush x:Key="EdgeStrongBrush" Color="{StaticResource EdgeStrong}" />
    <SolidColorBrush x:Key="InkDefaultBrush" Color="{StaticResource InkDefault}" />
    <SolidColorBrush x:Key="InkDimBrush" Color="{StaticResource InkDim}" />
    <SolidColorBrush x:Key="InkMutedBrush" Color="{StaticResource InkMuted}" />

    <!-- Tipografia -->
    <FontFamily x:Key="FontBody">Segoe UI</FontFamily>
    <FontFamily x:Key="FontDisplay">Segoe UI Semibold</FontFamily>
    <FontFamily x:Key="FontMono">Consolas, Cascadia Mono, Courier New</FontFamily>

    <!-- Stili base -->

    <!-- Sezione titolo (uppercase small-caps) -->
    <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontBody}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="ViewTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontDisplay}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{StaticResource InkDefaultBrush}" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="KpiValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource InkDefaultBrush}" />
    </Style>

    <Style x:Key="KpiLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}" />
    </Style>

    <!-- Bottone primario (accento arancione) -->
    <Style x:Key="BtnPrimary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrandAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource BrandAccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="FontFamily" Value="{StaticResource FontBody}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrandAccentDeepBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BrandAccentDeepBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Bottone secondario (outline neutro) -->
    <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{StaticResource InkDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EdgeMediumBrush}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PanelSubBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource EdgeStrongBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Toggle button — usato per il view switcher del DockablePane -->
    <Style x:Key="SwitcherButton" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource InkDimBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontFamily" Value="{StaticResource FontBody}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource InkDefaultBrush}" />
                <Setter Property="Background" Value="{StaticResource PanelSubBrush}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Foreground" Value="{StaticResource BrandAccentBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="BorderBrush" Value="{StaticResource BrandAccentBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Card container -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource EdgeLightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

</ResourceDictionary>
